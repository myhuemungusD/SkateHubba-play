{
  "name": "skatehubba-play",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rules": "firebase emulators:exec --only firestore,storage --project demo-skatehubba-rules 'vitest run --config rules-tests/vitest.config.ts'",
    "test:e2e": "firebase emulators:exec --only auth,firestore,storage --project demo-skatehubba 'playwright test'",
    "test:e2e:ui": "firebase emulators:exec --only auth,firestore,storage --project demo-skatehubba 'playwright test --ui'",
    "emulators": "firebase emulators:start --only auth,firestore,storage --project demo-skatehubba",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "cap run ios",
    "cap:run:android": "cap run android",
    "lint": "eslint src/ api/",
    "lint:fix": "eslint src/ api/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "check:test-dup": "node scripts/check-test-duplication.mjs",
    "check:file-length": "node scripts/check-file-length.mjs",
    "verify": "tsc -b && npm run lint && npm run test:coverage && npm run build && npm run check:test-dup",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor-community/video-recorder": "^7.5.0",
    "@capacitor-firebase/app-check": "^8.3.0",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/keyboard": "^8.0.4",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@sentry/capacitor": "4.2.0",
    "@sentry/react": "10.68.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^1.26.0",
    "mapbox-gl": "^3.27.0",
    "nsfwjs": "^4.3.0",
    "posthog-js": "^1.407.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@grpc/grpc-js": "^1.14.4",
    "@opentelemetry/core": "^2.8.0",
    "http-proxy-agent": "^7.0.2",
    "@xmldom/xmldom": "^0.9.10",
    "uuid": "^14.0.0",
    "ip-address": "^10.1.1",
    "hono": "^4.12.31",
    "basic-ftp": "^5.3.1",
    "dompurify": "^3.4.12",
    "fast-uri": "^3.1.4",
    "@hono/node-server": "^2.0.5",
    "protobufjs": "^7.5.8",
    "tmp": "^0.2.6",
    "@capacitor/cli": {
      "brace-expansion": "^5.0.7"
    },
    "@typescript-eslint/typescript-estree": {
      "brace-expansion": "^5.0.7"
    },
    "cacache": {
      "brace-expansion": "^5.0.7"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-tools": "^15.10.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  }
}
