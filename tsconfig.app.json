{
  "compilerOptions": {
    /* Language & environment */
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "esModuleInterop": true,

    /* Type checking */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Emit */
    "noEmit": true,
    "skipLibCheck": true,

    /* Project references */
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsBuildInfo"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.*", "src/**/*.spec.*", "src/__tests__/**", "src/__mocks__/**"]
}
