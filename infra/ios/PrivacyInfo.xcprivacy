<?xml version="1.0" encoding="UTF-8"?>
<!--
  iOS Privacy Manifest for SkateHubba.

  Apple requires this file on every app submitted to the App Store since
  1 May 2024 (see https://developer.apple.com/support/third-party-SDKs/).
  It declares:

    1. Whether the app performs cross-app/website tracking (we do NOT).
    2. The data categories we collect and why.
    3. Our use of "required-reason" APIs — categories of system APIs
       that Apple cross-checks against declared reasons.

  When `npx cap add ios` generates ios/App/App/, COPY this file to:

      ios/App/App/PrivacyInfo.xcprivacy

  and ADD it to the Xcode project (File → Add Files → App target, untick
  "Copy items if needed" since it's already in the filesystem). The
  Fastlane pipeline automates this step via `fastlane/Fastfile`.

  Keep in sync with:
    • firestore.rules  (which fields are written to profiles)
    • PrivacyPolicy.tsx (user-facing language must match collection list)
    • CHANGELOG.md on any collection-surface change (App Store reviewers
      compare the manifest to the privacy policy; drift causes rejections).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ── Tracking ──────────────────────────────────────────── -->
    <!-- SkateHubba does NOT track users across apps or websites. -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No third-party domains used for tracking. -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- ── Data collected ───────────────────────────────────── -->
    <!--
      Each entry declares a data category, whether it's linked to the
      user's identity, whether it's used for tracking, and the reasons.
      SkateHubba's data surface is deliberately narrow — the charter
      explicitly rules out cross-app tracking and advertising.
    -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>
        <!-- Email address — required for Firebase Auth account creation. -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeEmailAddress</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- User ID (Firebase UID + chosen username). -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeUserID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Photos or Videos — trick clips recorded during gameplay. -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePhotosorVideos</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Coarse location — only when a user opts into the Spots map. -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeCoarseLocation</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Crash data — Sentry captures exceptions to improve stability. -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeCrashData</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
                <string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
            </array>
        </dict>

        <!-- Performance data — Sentry + Vercel Speed Insights. -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePerformanceData</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
                <string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
            </array>
        </dict>

        <!-- Product interaction — Vercel Analytics (anonymous by default). -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeProductInteraction</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
            </array>
        </dict>

        <!--
          Other user content — username, stance, date of birth (stored for
          COPPA age-gate audit), game history. Linked to the account and
          used only for app functionality.
        -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherUserContent</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
    </array>

    <!-- ── Required-reason APIs ─────────────────────────────── -->
    <!--
      These are system APIs Apple tracks for fingerprinting risk. Each
      reason code maps to a permitted use case listed in:
        https://developer.apple.com/documentation/bundleresources/privacy_manifest_files/describing_use_of_required_reason_api
    -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- User defaults — Capacitor plugins cache lightweight state. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- File timestamp — local video caching / upload retry queues. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>C617.1</string>
            </array>
        </dict>

        <!-- Disk space — avoid starting an upload that can't complete. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>E174.1</string>
            </array>
        </dict>

        <!-- System boot time — measure app session duration (Sentry). -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySystemBootTime</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>35F9.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
