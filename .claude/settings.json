{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start-roster.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npm run verify)",
      "Bash(npm run check:*)",
      "Bash(npm run emulators)",
      "Bash(npm run dev)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(.claude/hooks/session-start-roster.sh)"
    ]
  }
}
