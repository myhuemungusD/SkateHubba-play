{
  "firestore": {
    "database": "skatehubba",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "predeploy": ["npm --prefix functions ci", "npm --prefix functions run build"]
  },
  "extensions": {
    "firestore-send-fcm": "firebase/firestore-send-fcm@0.1.16"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": false
    }
  }
}
