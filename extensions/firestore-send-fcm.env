# firebase/firestore-send-fcm — push dispatcher.
#
# This config wires the official Firebase extension to the /push_dispatch
# collection. The extension provisions a managed Cloud Run service (NOT a
# user-authored Cloud Function — the verify-no-cloud-functions CI gate
# blocks ^functions/src/, which extensions do not touch).
#
# Schema the extension reads (see src/services/pushDispatch.ts):
#   tokens:        string[]   — registration tokens for the recipient
#   notification:  { title, body }
#   data:          { gameId, type, click_action }
#
# Deploy:
#   firebase deploy --only extensions
#
# Upgrade:
#   firebase ext:install firebase/firestore-send-fcm --local
#   (then commit the regenerated .env)

# Cloud Firestore collection the extension listens to. MUST match
# PUSH_DISPATCH_COLLECTION in src/services/pushDispatch.ts. If you rename
# one, rename the other in lockstep.
COLLECTION_PATH=push_dispatch

# Time-to-live in seconds for each push. SKATE turn deadlines are 24h, so
# a 24h TTL prevents stale "your turn" pings from waking a phone the day
# AFTER the turn already expired and was auto-forfeited.
TTL=86400

# Firestore database. The project uses a named database ("skatehubba"),
# matching firebase.json firestore.database. Keep these aligned.
DATABASE=skatehubba

# Region for the managed dispatch worker. us-central1 matches Firebase's
# default and minimizes latency to the default Firestore region.
LOCATION=us-central1
