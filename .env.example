# SkateHubba S.K.A.T.E. Game — Environment Variables
# Get values from: Firebase Console → Project Settings → General → Your Apps → Web App
#
# ── Local Development ──
# Copy this file to .env.local and fill in your Firebase project values:
#   cp .env.example .env.local
#
# ── Vercel Preview / Production ──
# Add these variables in Vercel Dashboard → Project Settings → Environment Variables.
# Scope each variable to the environments you need (Preview, Production, or both).
# Preview deployments are created automatically for non-production branches and PRs.
# Each preview deployment gets a unique URL and a branch-specific URL.

# ── Required: Firebase ──────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Optional: Firebase Cloud Messaging (push notifications) ──────────────────────
# VAPID key for FCM web push — get from Firebase Console → Project Settings →
# Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=

# ── Optional: Firebase (recommended for production) ─────────────────────────────
# Measurement ID for Firebase Analytics (found in Firebase Console → Project Settings)
# VITE_FIREBASE_MEASUREMENT_ID=

# ── Optional: Firebase App Check (strongly recommended for production) ───────────
# reCAPTCHA v3 site key — get from Firebase Console → App Check → Register app
# Blocks non-app traffic (bots, API abuse). Without this key App Check is disabled.
# VITE_RECAPTCHA_SITE_KEY=

# Operator kill-switch. Set to "false" in Vercel to skip initializeAppCheck()
# entirely — use when App Check enforcement is ON in Firebase Console but
# reCAPTCHA is failing to mint tokens and every Firestore read comes back
# permission-denied. Redeploy takes ~30 s, no code change required. See
# docs/PERMISSION_DENIED_RUNBOOK.md for the full triage flow. Default: enabled.
# VITE_APPCHECK_ENABLED=false

# ── Optional: Sentry Error Tracking (recommended for production) ─────────────────
# DSN from Sentry Dashboard → Project → Settings → Client Keys
# Without this key Sentry is disabled — errors only appear in browser console.
# VITE_SENTRY_DSN=

# ── Optional: PostHog Analytics (funnels, cohorts, retention) ────────────────────
# Project API key — starts with "phc_". Get from PostHog → Project Settings →
# API Keys. Without this key PostHog is disabled and events no-op silently.
# Vercel Analytics still runs in parallel (sees every event either way).
# VITE_POSTHOG_KEY=
# Optional host override. US cloud (default): https://us.i.posthog.com
# EU cloud: https://eu.i.posthog.com — use whichever region you chose at signup.
# VITE_POSTHOG_HOST=

# ── Optional: App URL ─────────────────────────────────────────────────────────────
# Set to your production domain in Vercel env vars. Falls back to window.location.origin.
# Used for Firebase email action links (password reset, verification) and invite links.
# VITE_APP_URL=https://skatehubba.com

# ── Required for Map: Mapbox ─────────────────────────────────────────────────────
# Get from Mapbox Dashboard → Access Tokens
# Without this, the /map page will not render. The map silently fails without a token.
VITE_MAPBOX_TOKEN=
# Optional: custom Mapbox Studio style URL. Falls back to mapbox://styles/mapbox/dark-v11
# VITE_MAPBOX_STYLE_URL=

# ── Local development only ────────────────────────────────────────────────────────
# Set to "true" to use Firebase emulators (Auth :9099, Firestore :8080, Storage :9199)
# VITE_USE_EMULATORS=true
