# Large media files in src/ (use public/ for static assets)
src/**/*.mp4
src/**/*.webm
src/**/*.mov

# Capacitor native platforms — both tracked so we can customise manifests,
# entitlements, icons, signing configs, and Info.plist. Only build artefacts
# and per-developer Xcode state are ignored below.

# iOS (Capacitor/Xcode) — tracked project, ignore build + pod artefacts
ios/App/Pods/
ios/App/*.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/App/build/
ios/App/DerivedData/
ios/build/
# Podfile.lock is intentionally ignored for now: the Xcode project landed
# in this branch without a committed lockfile, and flipping to tracked
# mid-stream would churn against every parallel iOS branch that already
# regenerated its own lock. Revisit once the Capacitor/Firebase pod set
# stabilises — then commit it the same way we commit package-lock.json.
ios/App/Podfile.lock
