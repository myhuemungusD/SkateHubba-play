# One-shot seed tool output (scripts/seed-spots.py) — large data, regenerated
scripts/output/

# Large media files in src/ (use public/ for static assets)
src/**/*.mp4
src/**/*.webm
src/**/*.mov

# Capacitor native platforms — both tracked so we can customise manifests,
# entitlements, icons, signing configs, and Info.plist. Only build artefacts
# and per-developer Xcode state are ignored below.

# iOS (Capacitor/Xcode) — tracked project, ignore build + pod artefacts
ios/App/Pods/
ios/App/*.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/App/build/
ios/App/DerivedData/
ios/build/
# Firebase config — secret, never commit. Downloaded per ios/NATIVE_SETUP.md.
ios/App/App/GoogleService-Info.plist
android/app/google-services.json
# Podfile.lock is intentionally committed for reproducible iOS pod resolution.
# Regenerate with `pod install` on macOS and commit alongside Podfile changes.
