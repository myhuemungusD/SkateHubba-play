rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Game videos: only authenticated users can read/upload
    // Path: games/{gameId}/turn-{turnNumber}/{role}.webm
    // NOTE: Storage rules cannot cross-reference Firestore docs to verify
    // game membership. Firestore game rules enforce player validation.
    // Storage restricts to auth + size + content type.
    match /games/{gameId}/{turnPath}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024  // 50MB max per video
        && request.resource.contentType.matches('video/.*')
        && fileName.matches('.*\\.webm$');  // Only .webm files
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
