rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Game videos: only authenticated users can read/upload
    // Path: games/{gameId}/turn-{turnNumber}/{role}.webm (web) or {role}.mp4 (native)
    // NOTE: Storage rules cannot cross-reference Firestore docs to verify
    // game membership. Firestore game rules enforce player validation.
    // Storage restricts to auth + size bounds + content type + exact filename.
    match /games/{gameId}/{turnPath}/{fileName} {
      allow read: if request.auth != null;
      // Create: authenticated + size/type constraints + uid binding.
      // The uploader stamps customMetadata.uploaderUid at upload time
      // (see src/services/storage.ts) so we can enforce ownership here —
      // the path itself does not encode uid because turn ownership flips
      // each round.
      allow create: if request.auth != null
        // Minimum 1 KB — prevents empty/stub uploads
        && request.resource.size > 1024
        // Maximum 50 MB per video
        && request.resource.size < 50 * 1024 * 1024
        // Must be a valid video type: webm (web) or mp4 (native/Capacitor)
        && (request.resource.contentType == 'video/webm'
            || request.resource.contentType == 'video/mp4')
        // Only the two known roles are valid filenames (rejects path traversal attempts)
        && fileName.matches('(set|match)\\.(webm|mp4)')
        // Bind the new object to its uploader so delete can verify ownership.
        && request.resource.metadata.uploaderUid == request.auth.uid;
      // NOTE: `update` is intentionally NOT granted. Game-video objects are
      // append-only from the rules' perspective: once committed they must
      // not be mutated, because Firestore `clips/*` docs (immutable via
      // `allow update: if false`) reference these URLs as the content-
      // moderation audit trail. Allowing update would let the uploader
      // silently swap the bytes behind an already-moderated clip.
      // If the client needs retry-on-failure semantics, it must `delete`
      // the old object and `create` a fresh one — the `create` rule re-
      // binds uploaderUid, size, MIME, and filename pattern from scratch.
      // (Firebase SDK `uploadBytesResumable` only commits on full success,
      // so a failed first attempt leaves no object to collide with — no
      // client-side delete is needed for the normal retry path.)
      // Delete: only the original uploader may remove their own video
      // (used during account-deletion cleanup for that user's own clips).
      allow delete: if request.auth != null
        && resource.metadata.uploaderUid == request.auth.uid;
    }

    // ── Avatar uploads (PR-B) ──
    // Owner-only create + delete. ≤2 MB. Content-type pinning.
    // `update: if false` forces delete-then-create on re-upload (audit S11)
    // so a prior moderation pass cannot be silently overwritten with new
    // bytes behind the same URL.
    //
    // Anyone-auth read so /profile/{uid} pages on either own- or opponent-
    // view can render the avatar without a per-user grant. The Firestore
    // rule separately pins `users/{uid}.profileImageUrl` to this
    // bucket + the writer's UID, so a malicious profile cannot point at
    // another user's avatar (audit S5+S12).
    // NOTE: the Storage rules grammar does NOT support `{var}` segments
    // mid-path-segment (only whole path segments). The working equivalent
    // uses a single wildcard `{filename}` and a regex match on the filename
    // — same effect (uid pinning + ext allowlist), syntactically valid.
    match /users/{uid}/{filename} {
      allow read: if request.auth != null && filename.matches('avatar\\.(webp|jpeg|png)');

      allow create: if request.auth != null
        && request.auth.uid == uid
        // Per-extension content-type pinning (audit B-ISSUE-3): the
        // extension and the contentType MUST agree. Previously the
        // bare `matches(...)` allowlist permitted `avatar.webp` with
        // `content-type: image/png`, letting a client lie about the
        // payload format.
        && (
          (filename == 'avatar.webp' && request.resource.contentType == 'image/webp')
          || (filename == 'avatar.jpeg' && request.resource.contentType == 'image/jpeg')
          || (filename == 'avatar.png' && request.resource.contentType == 'image/png')
        )
        && request.resource.size > 1024
        && request.resource.size <= 2 * 1024 * 1024;

      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.uid == uid
        && filename.matches('avatar\\.(webp|jpeg|png)');
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
