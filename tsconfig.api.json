{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.api.tsBuildInfo"
  },
  "include": [
    "api",
    "src/services/turnForfeit.shared.ts",
    "src/services/turnDuration.ts",
    "src/services/games.mappers.ts",
    "src/constants/trickCategories.ts"
  ]
}
