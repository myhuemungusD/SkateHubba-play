rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPlayer(game) {
      return isSignedIn() && (
        request.auth.uid == game.player1Uid ||
        request.auth.uid == game.player2Uid
      );
    }

    // A judge is a non-player third user nominated at game creation who
    // rules on disputes and "Call BS" claims. Judge fields may be null on
    // honor-system games — always guard with 'judgeId' in-check first.
    function isJudge(game) {
      return isSignedIn()
        && 'judgeId' in game
        && game.judgeId != null
        && request.auth.uid == game.judgeId;
    }

    // Game doc is readable by either player OR the nominated judge.
    function isParticipant(game) {
      return isPlayer(game) || isJudge(game);
    }

    // True when a judge is actively seated (accepted the invite). Honor-system
    // rules apply until this is true — no dispute/BS transitions permitted.
    function judgeActive(game) {
      return 'judgeId' in game && game.judgeId != null
        && 'judgeStatus' in game && game.judgeStatus == 'accepted';
    }

    // ── turnHistory growth bounds ──
    // Every write path that legitimately appends to `games.turnHistory`
    // (match resolution, dispute resolution, Call BS resolution, expired
    // dispute auto-accept, expired setReview auto-clear) must satisfy BOTH:
    //
    //   (1) size grows by at most ONE entry per write — otherwise a player
    //       could `arrayUnion` a giant batch of fabricated TurnRecords.
    //   (2) absolute size stays ≤ 200 — a SKATE game tops out at roughly
    //       5 letters × 2 players × ~10 attempts per letter, so 200 is a
    //       generous ceiling that still protects against the 1 MB
    //       Firestore doc limit when an attacker inflates TurnRecord blobs.
    //
    // Accepts the same "absent on both sides" and "unchanged" shapes that
    // the non-growth branches use, so write paths that DON'T append
    // (e.g. a judge ruling that doesn't add a turn) still pass cleanly.
    function turnHistoryGrowthOk() {
      return (
        (!('turnHistory' in resource.data) && !('turnHistory' in request.resource.data))
        || (
          'turnHistory' in request.resource.data
          && request.resource.data.turnHistory is list
          && request.resource.data.turnHistory.size() <= 200
          && (
            // Unchanged (e.g. judge accepts without adding a record, or the
            // resource has the field and the request keeps it identical).
            ('turnHistory' in resource.data
              && request.resource.data.turnHistory == resource.data.turnHistory)
            // Appended exactly one entry to an existing history array.
            || ('turnHistory' in resource.data
                && request.resource.data.turnHistory.size() == resource.data.turnHistory.size() + 1)
            // First-ever append: resource has no turnHistory yet, request
            // introduces a single-entry list.
            || (!('turnHistory' in resource.data)
                && request.resource.data.turnHistory.size() <= 1)
          )
        )
      );
    }

    // ── Users ──
    // The `users/{uid}` document holds ONLY fields that are safe to expose
    // cross-user (username, stance, wins/losses, isVerifiedPro, …). Any
    // sensitive field — email, emailVerified, dob, parentalConsent, and
    // the `fcmTokens` push-registration list — lives in the private
    // subcollection `users/{uid}/private/*` and is readable only by the
    // owning user. Firestore rules cannot filter fields on reads, so the
    // split at the document boundary is the enforcement mechanism.
    //
    // ⚠️ TRANSITIONAL RULES (April 2026 public/private split) ⚠️
    // Legacy production `users/{uid}` docs still carry the five sensitive
    // fields inline. `request.resource.data` is the MERGED post-write state,
    // so an `updateDoc({ wins: 3 })` against a legacy doc would include
    // every untouched legacy field in `request.resource.data` — a strict
    // `!('email' in request.resource.data)` guard would reject every
    // legitimate partial update (wins++, profile edits, etc.) until the
    // backfill migration (see scripts/migrate-users-private.mjs) completes.
    //
    // The relaxed form below accepts a sensitive field on `update` IFF it
    // is unchanged from `resource.data` (i.e. an untouched legacy value
    // riding along with a legitimate write). New creates remain strict,
    // so no post-deploy client can introduce these fields on a fresh doc.
    // After the backfill script removes every legacy inline occurrence,
    // tighten the `update` rule back to a strict `!('X' in request.resource.data)`
    // check — tracked as a follow-up TODO in docs/DATABASE.md.
    //
    // Username constraints MUST match `USERNAME_MIN`, `USERNAME_MAX`, and
    // `USERNAME_RE` in src/services/users.ts. Rules are the source of truth
    // at the security boundary; the TS constants exist so the UI can reject
    // invalid input before a round-trip. Update BOTH when changing limits.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid)
        // One profile per UID — prevent a race condition from overwriting an existing profile
        && !exists(/databases/$(database)/documents/users/$(uid))
        && request.resource.data.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3  // USERNAME_MIN
        && request.resource.data.username.size() <= 20 // USERNAME_MAX
        // Enforce lowercase alphanumeric + underscore only (matches client-side normalisation)
        && request.resource.data.username.matches('[a-z0-9_]+') // USERNAME_RE body
        // wins/losses must start at zero if present (prevents leaderboard inflation
        // by injecting arbitrary stats at profile creation time)
        && (!('wins' in request.resource.data) || request.resource.data.wins == 0)
        && (!('losses' in request.resource.data) || request.resource.data.losses == 0)
        // Pro fields are admin-only — clients cannot set them at creation
        && !('isVerifiedPro' in request.resource.data)
        && !('verifiedBy' in request.resource.data)
        && !('verifiedAt' in request.resource.data)
        // Sensitive fields MUST live in users/{uid}/private/* instead of
        // the public profile doc. Strict on CREATE — no new doc may
        // introduce them. (Legacy docs are handled by the update rule below.)
        && !('email' in request.resource.data)
        && !('emailVerified' in request.resource.data)
        && !('dob' in request.resource.data)
        && !('parentalConsent' in request.resource.data)
        && !('fcmTokens' in request.resource.data)
        // Rate-limit cooldown anchors are server-managed: the only legitimate
        // writer is the best-effort `setDoc(…, { merge: true })` that fires
        // AFTER a successful game / spot create (see
        // src/services/games.ts and src/services/spots.ts). Seeding them at
        // profile-create time is pure attack surface — a stale value would
        // instantly satisfy the 30s cooldown the first time the user creates
        // a game or spot. Require the fields to be absent on create; the
        // update rule then pins any future write to serverTimestamp().
        && !('lastGameCreatedAt' in request.resource.data)
        && !('lastSpotCreatedAt' in request.resource.data);
      allow update: if isOwner(uid)
        // Cannot change username or uid after creation
        && request.resource.data.username == resource.data.username
        && request.resource.data.uid == resource.data.uid
        // Pro fields are admin-only — clients cannot modify them
        && (!('isVerifiedPro' in request.resource.data) || request.resource.data.isVerifiedPro == resource.data.isVerifiedPro)
        && (!('verifiedBy' in request.resource.data) || request.resource.data.verifiedBy == resource.data.verifiedBy)
        && (!('verifiedAt' in request.resource.data) || request.resource.data.verifiedAt == resource.data.verifiedAt)
        // Sensitive fields — transitional form. A legacy doc that still
        // carries e.g. `email` inline will have `email` in
        // `request.resource.data` on every partial update (merged state).
        // Accept it IFF the value is unchanged from resource.data — this
        // lets legitimate non-sensitive writes (wins++, stance change)
        // ride alongside untouched legacy fields while still rejecting
        // any attempt to re-introduce or modify the field. The strict
        // form will be restored once backfill completes.
        && (!('email' in request.resource.data)
            || ('email' in resource.data && request.resource.data.email == resource.data.email))
        && (!('emailVerified' in request.resource.data)
            || ('emailVerified' in resource.data && request.resource.data.emailVerified == resource.data.emailVerified))
        && (!('dob' in request.resource.data)
            || ('dob' in resource.data && request.resource.data.dob == resource.data.dob))
        && (!('parentalConsent' in request.resource.data)
            || ('parentalConsent' in resource.data && request.resource.data.parentalConsent == resource.data.parentalConsent))
        && (!('fcmTokens' in request.resource.data)
            || ('fcmTokens' in resource.data && request.resource.data.fcmTokens == resource.data.fcmTokens))
        // Wins/losses can only increment by 0 or 1 per write.
        // When the field doesn't exist yet, only 0 or 1 is allowed
        // (the old rule's !('wins' in resource.data) branch accepted any value).
        && (
          !('wins' in request.resource.data)
          || (!('wins' in resource.data)
              && request.resource.data.wins >= 0 && request.resource.data.wins <= 1)
          || ('wins' in resource.data && (
            request.resource.data.wins == resource.data.wins
            || request.resource.data.wins == resource.data.wins + 1
          ))
        )
        && (
          !('losses' in request.resource.data)
          || (!('losses' in resource.data)
              && request.resource.data.losses >= 0 && request.resource.data.losses <= 1)
          || ('losses' in resource.data && (
            request.resource.data.losses == resource.data.losses
            || request.resource.data.losses == resource.data.losses + 1
          ))
        )
        // lastGameCreatedAt is the server-side 30s game-creation cooldown
        // anchor (see /games create rule). Without this guard, a client
        // could write a stale Timestamp (e.g. epoch 0) to instantly satisfy
        // the `request.time > lastGameCreatedAt + 30s` check and spam games.
        // `request.resource.data` reflects the merged post-write state, so
        // a partial update that doesn't touch the field still carries the
        // stored value through — the three accepted branches are:
        //   (A) neither stored nor post-write have it (no cooldown state yet)
        //   (B) both have it and the value is unchanged (untouched update)
        //   (C) the new value equals request.time (client wrote
        //       serverTimestamp()), which is what the game-create flow does
        //       after addDoc().
        && (
          (!('lastGameCreatedAt' in request.resource.data)
            && !('lastGameCreatedAt' in resource.data))
          || ('lastGameCreatedAt' in resource.data
              && 'lastGameCreatedAt' in request.resource.data
              && request.resource.data.lastGameCreatedAt == resource.data.lastGameCreatedAt)
          || request.resource.data.lastGameCreatedAt == request.time
        )
        // lastSpotCreatedAt is the sibling 30s cooldown anchor for spot
        // creation (see /spots create rule). Exact same attack surface and
        // exact same three-branch guard — kept in lockstep with
        // lastGameCreatedAt above. The spot-create flow writes this via
        // `setDoc(…, { lastSpotCreatedAt: serverTimestamp() }, { merge: true })`
        // in src/services/spots.ts after addDoc().
        && (
          (!('lastSpotCreatedAt' in request.resource.data)
            && !('lastSpotCreatedAt' in resource.data))
          || ('lastSpotCreatedAt' in resource.data
              && 'lastSpotCreatedAt' in request.resource.data
              && request.resource.data.lastSpotCreatedAt == resource.data.lastSpotCreatedAt)
          || request.resource.data.lastSpotCreatedAt == request.time
        );
      // Users may delete their own profile (account deletion flow)
      allow delete: if isOwner(uid);

      // ── Private profile (subcollection) ──
      // Owner-only read/write surface for sensitive fields that must
      // never leak cross-user: email, emailVerified, dob, parentalConsent,
      // and the fcmTokens push-registration list. The canonical doc is
      // `users/{uid}/private/profile`; {docId} is open in the matcher so
      // a future split (e.g. `users/{uid}/private/fcm`) doesn't require
      // a rules change, but every doc stays owner-only.
      //
      // The fcmTokens cap (≤10 entries, must be a list) moves with the
      // field — prevents a compromised client from stuffing an unbounded
      // blob into the push-token list, the same attack the previous
      // guard on the public user doc closed.
      match /private/{docId} {
        allow read: if isOwner(uid);

        // ── fcmTokens cap ──
        // Every push registration write goes here; cap at ≤10 entries
        // (one per device the user is currently signed into). String type
        // is not enforced individually because the FCM SDK opaquely wraps
        // them, but list shape is mandatory.
        function fcmTokensOk() {
          return !('fcmTokens' in request.resource.data)
            || (request.resource.data.fcmTokens is list
                && request.resource.data.fcmTokens.size() <= 10);
        }

        // ── Onboarding field shape validation ──
        // The onboarding service (src/services/onboarding.ts) writes three
        // fields here via setDoc(..., { merge: true }):
        //   - onboardingTutorialVersion: int >= 0  (TUTORIAL_VERSION bump
        //                                            is monotonic; null is
        //                                            valid only via the
        //                                            explicit reset path)
        //   - onboardingCompletedAt:    serverTimestamp() | null | timestamp ≤ now+5s
        //   - onboardingSkippedAt:      serverTimestamp() | null | timestamp ≤ now+5s
        //
        // Without these checks a malicious client can stuff arbitrary
        // shapes ("attack", { nested: true }, etc.) into the private doc
        // and wedge readers in src/services/onboarding.ts that do
        // `typeof === "number"` / Timestamp duck-typing. Each predicate is
        // gated on `field in request.resource.data` so unrelated writes
        // (fcmTokens, emailVerified, etc.) pay zero validation cost.
        //
        // The serverTimestamp() sentinel is detected via the same idiom
        // already in use elsewhere in this file (see lastGameCreatedAt /
        // lastSpotCreatedAt above): when the client uses the sentinel,
        // `request.resource.data.field == request.time`.
        function onboardingTutorialVersionOk() {
          return !('onboardingTutorialVersion' in request.resource.data)
            || request.resource.data.onboardingTutorialVersion == null
            || (request.resource.data.onboardingTutorialVersion is int
                && request.resource.data.onboardingTutorialVersion >= 0);
        }
        function onboardingCompletedAtOk() {
          return !('onboardingCompletedAt' in request.resource.data)
            || request.resource.data.onboardingCompletedAt == null
            || request.resource.data.onboardingCompletedAt == request.time
            || (request.resource.data.onboardingCompletedAt is timestamp
                && request.resource.data.onboardingCompletedAt <= request.time + duration.value(5, 's'));
        }
        function onboardingSkippedAtOk() {
          return !('onboardingSkippedAt' in request.resource.data)
            || request.resource.data.onboardingSkippedAt == null
            || request.resource.data.onboardingSkippedAt == request.time
            || (request.resource.data.onboardingSkippedAt is timestamp
                && request.resource.data.onboardingSkippedAt <= request.time + duration.value(5, 's'));
        }

        // ── Allowlist of accepted keys ──
        // Every key currently written to users/{uid}/private/profile by
        // the codebase. Keep in sync with UserPrivateProfile in
        // src/services/users.ts and the onboarding writers in
        // src/services/onboarding.ts. An unknown key here is a bug or an
        // attack — fail closed.
        function privateProfileKeysOk() {
          return request.resource.data.keys().hasOnly([
            'emailVerified',
            'dob',
            'parentalConsent',
            'fcmTokens',
            'onboardingTutorialVersion',
            'onboardingCompletedAt',
            'onboardingSkippedAt'
          ]);
        }

        allow create: if isOwner(uid)
          && privateProfileKeysOk()
          && fcmTokensOk()
          && onboardingTutorialVersionOk()
          && onboardingCompletedAtOk()
          && onboardingSkippedAtOk();
        allow update: if isOwner(uid)
          && privateProfileKeysOk()
          && fcmTokensOk()
          && onboardingTutorialVersionOk()
          && onboardingCompletedAtOk()
          && onboardingSkippedAtOk();
        allow delete: if isOwner(uid);
      }

      // ── Blocked Users (subcollection) ──
      // Each user maintains their own block list.  Only the owner can
      // create, read, or delete entries.  Blocking is bidirectional at
      // the application layer — game creation checks both directions.
      match /blocked_users/{blockedUid} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.blockedUid == blockedUid
          && request.resource.data.blockedUid is string
          // Cannot block yourself
          && blockedUid != uid;
        allow update: if false;
        allow delete: if isOwner(uid);
      }
    }

    // ── Usernames (reservation docs for uniqueness) ──
    // Same constraints as users/{uid}.username above — keep in sync with
    // USERNAME_MIN/MAX/RE in src/services/users.ts.
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && username.size() >= 3  // USERNAME_MIN
        && username.size() <= 20 // USERNAME_MAX
        // Reservation key must be a valid username (lowercase alphanum + underscore)
        && username.matches('[a-z0-9_]+'); // USERNAME_RE body
      // Cannot be updated; only the owning user can delete (account deletion flow)
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Helper: determine the opponent of a player ──
    function opponentUid(game, uid) {
      return uid == game.player1Uid ? game.player2Uid : game.player1Uid;
    }

    // ── Games ──
    match /games/{gameId} {
      // Players AND the nominated judge can read the game document.
      allow read: if isSignedIn() && isParticipant(resource.data);

      // Any signed-in user with a verified email can create a game (as player1).
      // Email verification is enforced server-side here so it can't be bypassed
      // by calling the Firestore API directly (e.g. from the browser console).
      // Rate limit: user profile must have been updated > 30s ago (prevents spam creation).
      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.player1Uid == request.auth.uid
        // Prevent self-challenge: player2 must be a different account
        && request.resource.data.player2Uid != request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.p1Letters == 0
        && request.resource.data.p2Letters == 0
        && request.resource.data.turnNumber == 1
        && request.resource.data.winner == null
        // Challenger always has the first turn and sets first trick
        && request.resource.data.currentTurn == request.auth.uid
        && request.resource.data.phase == 'setting'
        && request.resource.data.currentSetter == request.auth.uid
        // turnDeadline must be a future timestamp (prevents instant-forfeit attack:
        // without this, a malicious client could set turnDeadline in the past,
        // currentTurn to the opponent, and immediately forfeit them).
        // Upper bound prevents the inverse attack: without a cap, a client
        // could set turnDeadline to Timestamp.fromMillis(Number.MAX_SAFE_INTEGER)
        // and permanently block the opponent's forfeit path (forfeit needs
        // request.time > resource.data.turnDeadline). 48h is 2× the production
        // TURN_DURATION_MS (24h) — tight enough to prevent abuse, loose enough
        // to tolerate clock skew and retry windows.
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        && request.resource.data.turnDeadline < request.time + duration.value(48, 'h')
        // Trick/video fields must start empty
        && request.resource.data.currentTrickName == null
        && request.resource.data.currentTrickVideoUrl == null
        && request.resource.data.matchVideoUrl == null
        // Optional spotId must be a string if present (location context for
        // the challenge — clients validate UUID shape, rules enforce the
        // coarser type invariant).
        && (
          !('spotId' in request.resource.data)
          || (request.resource.data.spotId is string
              && request.resource.data.spotId.size() <= 64)
        )
        // Judge fields must be present with correct shape. judgeId can be
        // null (honor system) or a non-player string UID. When judgeId is
        // set, judgeStatus must start as 'pending'. When null, judgeStatus
        // must also be null. This keeps invariants enforceable for updates.
        && (
          !('judgeId' in request.resource.data)
          || request.resource.data.judgeId == null
          || (request.resource.data.judgeId is string
              && request.resource.data.judgeId != request.auth.uid
              && request.resource.data.judgeId != request.resource.data.player2Uid)
        )
        && (
          !('judgeStatus' in request.resource.data)
          || (request.resource.data.judgeId == null && request.resource.data.judgeStatus == null)
          || (request.resource.data.judgeId != null && request.resource.data.judgeStatus == 'pending')
        )
        // Rate limit: at most one game creation per 30 seconds per user.
        // Checks the user's lastGameCreatedAt field — if it doesn't exist
        // (first game ever) the condition is satisfied automatically.
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || !('lastGameCreatedAt' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
          || request.time > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastGameCreatedAt + duration.value(30, 's')
        )
        // Block check: neither player may have blocked the other.
        // Uses exists() against both directions of the blocked_users subcollection.
        && !exists(/databases/$(database)/documents/users/$(request.auth.uid)/blocked_users/$(request.resource.data.player2Uid))
        && !exists(/databases/$(database)/documents/users/$(request.resource.data.player2Uid)/blocked_users/$(request.auth.uid));

      // Current-turn player can make normal game updates
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && request.auth.uid == resource.data.currentTurn
        // Rate limit: at most one turn action per 2 seconds (prevents write flooding).
        // The cooldown below compares against the STORED updatedAt; without
        // also pinning the NEW updatedAt to request.time, a client could write
        // a stale value (e.g. epoch 0) and permanently satisfy the check.
        // Mirrors the same hardening on notification_limits / nudge_limits.
        && 'updatedAt' in request.resource.data
        && request.resource.data.updatedAt == request.time
        && (
          !('updatedAt' in resource.data)
          || resource.data.updatedAt == null
          || request.time > resource.data.updatedAt + duration.value(2, 's')
        )
        // Cannot change player UIDs or usernames
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        // spotId is set at creation and immutable thereafter. Explicit `in`
        // checks here rather than .get(field, null) because the latter
        // throws "Null value error" in current Firestore rules engines.
        && (
          (!('spotId' in resource.data) && !('spotId' in request.resource.data))
          || ('spotId' in resource.data && 'spotId' in request.resource.data
              && request.resource.data.spotId == resource.data.spotId)
        )
        // Judge identity is immutable after creation. judgeStatus may only
        // change via dedicated accept/decline rules below.
        && (
          (!('judgeId' in resource.data) && !('judgeId' in request.resource.data))
          || ('judgeId' in resource.data && 'judgeId' in request.resource.data
              && request.resource.data.judgeId == resource.data.judgeId)
        )
        && (
          (!('judgeStatus' in resource.data) && !('judgeStatus' in request.resource.data))
          || ('judgeStatus' in resource.data && 'judgeStatus' in request.resource.data
              && request.resource.data.judgeStatus == resource.data.judgeStatus)
        )
        // currentTurn must always be one of the two players after the update
        && (
          request.resource.data.currentTurn == resource.data.player1Uid ||
          request.resource.data.currentTurn == resource.data.player2Uid
        )
        // turnDeadline must be a timestamp bounded to a sane future window.
        // See the create rule above for the rationale on the 48h upper bound
        // (blocks opponent-lockout via Timestamp.fromMillis(MAX_SAFE_INTEGER)).
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        && request.resource.data.turnDeadline < request.time + duration.value(48, 'h')
        // Scores must not change during setting-phase updates.
        // Letters are only awarded via the match resolution rule below.
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        // Game stays active, no winner (completion only via match resolution or forfeit)
        && request.resource.data.status == 'active'
        && request.resource.data.winner == null
        // matchVideoUrl is only written by the matching-phase rule — setting
        // phase updates must not touch it. Without this pin, a setter whose
        // currentTurn == uid could stash a match video and then forge a
        // subsequent matching→setting forfeit/resolution against it.
        && request.resource.data.matchVideoUrl == resource.data.matchVideoUrl
        // Valid phase transitions only (prevents skipping phases). Each
        // branch pins the exact fields that MUST change and the ones that
        // MUST NOT — without these pins, the setter could rewrite
        // currentSetter / turnNumber / trick fields to forge a state where
        // the opponent's turnDeadline has already expired, and then invoke
        // the forfeit branch below to win unilaterally.
        && (
          // setting → matching (setter sets a trick)
          //   • currentSetter stays put (role doesn't change until the match resolves)
          //   • turn swaps to the matcher (opponent of the setter)
          //   • turnNumber is unchanged (phase change within the same turn)
          //   • currentTrickName / currentTrickVideoUrl are populated with the set trick
          (resource.data.phase == 'setting'
           && request.resource.data.phase == 'matching'
           && request.resource.data.currentSetter == resource.data.currentSetter
           && request.resource.data.currentTurn == opponentUid(resource.data, resource.data.currentSetter)
           && request.resource.data.turnNumber == resource.data.turnNumber
           && request.resource.data.currentTrickName is string
           && request.resource.data.currentTrickName.size() > 0
           && request.resource.data.currentTrickName.size() <= 64
           && request.resource.data.currentTrickVideoUrl is string
           // Pin trick-video URL to Firebase Storage hosts only. Without this
           // anchor, a setter could point currentTrickVideoUrl at any HTTP
           // origin — exfiltrating viewer IPs via referrer/preconnect, or
           // serving NSFW/malicious media inside the matcher's recorder UI.
           // Mirrors the client-side `isFirebaseStorageUrl` helper
           // (src/utils/helpers.ts): the legacy
           // firebasestorage.googleapis.com host (literal) and the newer
           // bucket-as-subdomain *.firebasestorage.app host.
           && request.resource.data.currentTrickVideoUrl.matches('^https://(firebasestorage\\.googleapis\\.com|[^/]+\\.firebasestorage\\.app)/.+'))
          // setting → setting (setter failed to land, turn passes to opponent)
          //   • currentSetter MUST flip to the other player (the whole point of
          //     failSetTrick is the role passes) — this is the invariant the
          //     exploit targets: without it, the setter could keep the role and
          //     merely reassign currentTurn to the opponent
          //   • currentTurn follows currentSetter (new setter sets first)
          //   • turnNumber strictly increments (fresh turn)
          //   • trick fields reset to null (no trick set yet this turn)
          || (resource.data.phase == 'setting'
              && request.resource.data.phase == 'setting'
              && request.resource.data.currentSetter == opponentUid(resource.data, resource.data.currentSetter)
              && request.resource.data.currentTurn == request.resource.data.currentSetter
              && request.resource.data.turnNumber == resource.data.turnNumber + 1
              && request.resource.data.currentTrickName == null
              && request.resource.data.currentTrickVideoUrl == null)
        )
        // turnHistory must not change during setting-phase updates
        && (
          (!('turnHistory' in resource.data) && !('turnHistory' in request.resource.data))
          || request.resource.data.turnHistory == resource.data.turnHistory
        );

      // ── Match resolution (matcher submits an attempt) ──
      // Honor system (no active judge):
      //   • missed  → matcher +1 letter, phase=setting (or complete)
      //   • landed  → matcher's call stands; roles swap, phase=setting
      // With active judge:
      //   • missed  → matcher +1 letter (matcher admitting doesn't dispute)
      //   • landed  → phase=disputable, currentTurn routes to judge
      //
      // Call BS (judge only): matcher transitions matching → setReview with
      // currentTurn = judgeId. Split out as its own branch for clarity.
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && resource.data.phase == 'matching'
        && request.auth.uid == resource.data.currentTurn
        // Rate limit. New updatedAt must equal request.time — prevents the
        // stored-value spoof where a client writes epoch 0 to keep the 2s
        // cooldown permanently satisfied. Same pattern as notification_limits.
        && 'updatedAt' in request.resource.data
        && request.resource.data.updatedAt == request.time
        && (
          !('updatedAt' in resource.data)
          || resource.data.updatedAt == null
          || request.time > resource.data.updatedAt + duration.value(2, 's')
        )
        // Cannot change player UIDs or usernames
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        // spotId immutable
        && (
          (!('spotId' in resource.data) && !('spotId' in request.resource.data))
          || ('spotId' in resource.data && 'spotId' in request.resource.data
              && request.resource.data.spotId == resource.data.spotId)
        )
        // Judge identity + status immutable during match resolution
        && (
          (!('judgeId' in resource.data) && !('judgeId' in request.resource.data))
          || ('judgeId' in resource.data && 'judgeId' in request.resource.data
              && request.resource.data.judgeId == resource.data.judgeId)
        )
        && (
          (!('judgeStatus' in resource.data) && !('judgeStatus' in request.resource.data))
          || ('judgeStatus' in resource.data && 'judgeStatus' in request.resource.data
              && request.resource.data.judgeStatus == resource.data.judgeStatus)
        )
        // turnDeadline must be a timestamp bounded to a sane future window
        // (see create rule for rationale on the 48h cap).
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        && request.resource.data.turnDeadline < request.time + duration.value(48, 'h')
        // Letters: at most one player gains exactly one letter (missed) or none change (landed)
        && (
          // No letter change (landed path, both honor + judge)
          (request.resource.data.p1Letters == resource.data.p1Letters
           && request.resource.data.p2Letters == resource.data.p2Letters)
          // Missed — exactly one player gets +1
          || (request.resource.data.p1Letters == resource.data.p1Letters + 1
              && request.resource.data.p2Letters == resource.data.p2Letters)
          || (request.resource.data.p1Letters == resource.data.p1Letters
              && request.resource.data.p2Letters == resource.data.p2Letters + 1)
        )
        // Valid outcomes depend on whether a judge is active.
        && (
          // Missed path — immediate resolution, both branches. currentTurn
          // stays on a player (same setter). Game may complete here.
          (request.resource.data.status == 'active'
           && request.resource.data.phase == 'setting'
           && request.resource.data.winner == null
           && (
             request.resource.data.currentTurn == resource.data.player1Uid
             || request.resource.data.currentTurn == resource.data.player2Uid
           ))
          // Completion: pin winner to the opponent of the player who just
          // hit 5 letters. Without this pin, a losing matcher whose own
          // counter just reached 5 could write `winner = themselves` —
          // every read of the doc (leaderboard, clip feed, push, profile)
          // would then surface the wrong outcome.
          || (request.resource.data.status == 'complete'
              && request.resource.data.winner != null
              && (
                (request.resource.data.p1Letters >= 5
                 && request.resource.data.winner == resource.data.player2Uid)
                || (request.resource.data.p2Letters >= 5
                    && request.resource.data.winner == resource.data.player1Uid)
              ))
          // Honor system + landed — roles swap immediately, no judge routing.
          // Letters must stay unchanged; currentTurn becomes the matcher
          // (opponent of resource.data.currentSetter). Only allowed when the
          // judge is NOT active.
          || (!judgeActive(resource.data)
              && request.resource.data.status == 'active'
              && request.resource.data.phase == 'setting'
              && request.resource.data.winner == null
              && request.resource.data.p1Letters == resource.data.p1Letters
              && request.resource.data.p2Letters == resource.data.p2Letters
              && request.resource.data.currentTurn == opponentUid(resource.data, resource.data.currentSetter))
          // Judge-active + landed — enter disputable, route currentTurn to judge.
          || (judgeActive(resource.data)
              && request.resource.data.status == 'active'
              && request.resource.data.phase == 'disputable'
              && request.resource.data.winner == null
              && request.resource.data.p1Letters == resource.data.p1Letters
              && request.resource.data.p2Letters == resource.data.p2Letters
              && request.resource.data.currentTurn == resource.data.judgeId)
          // Judge-active + Call BS — enter setReview, route currentTurn to judge.
          // Letters unchanged; matchVideoUrl unchanged (no attempt recorded).
          || (judgeActive(resource.data)
              && request.resource.data.status == 'active'
              && request.resource.data.phase == 'setReview'
              && request.resource.data.winner == null
              && request.resource.data.p1Letters == resource.data.p1Letters
              && request.resource.data.p2Letters == resource.data.p2Letters
              && request.resource.data.currentTurn == resource.data.judgeId)
        )
        // turnHistory growth bound — cap appends to 1 per write and total
        // size to 200 entries. Prevents a 1 MB TurnRecord balloon attack
        // against the Firestore doc-size ceiling.
        && turnHistoryGrowthOk();

      // ── Dispute resolution (judge rules on the matcher's "landed" claim) ──
      // Judge-only. The setter never self-judges — disputes only exist in
      // games with an active judge. Judge accepts (no letters, roles swap)
      // or overrules (matcher +1 letter, setter keeps setting).
      allow update: if isSignedIn()
        && isJudge(resource.data)
        && resource.data.status == 'active'
        && resource.data.phase == 'disputable'
        && request.auth.uid == resource.data.currentTurn
        && judgeActive(resource.data)
        // Rate limit. Pinning updatedAt to request.time closes the
        // stale-value bypass (see setting-phase rule above for rationale).
        && 'updatedAt' in request.resource.data
        && request.resource.data.updatedAt == request.time
        && (
          !('updatedAt' in resource.data)
          || resource.data.updatedAt == null
          || request.time > resource.data.updatedAt + duration.value(2, 's')
        )
        // Cannot change player UIDs or usernames
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        // spotId immutable
        && (
          (!('spotId' in resource.data) && !('spotId' in request.resource.data))
          || ('spotId' in resource.data && 'spotId' in request.resource.data
              && request.resource.data.spotId == resource.data.spotId)
        )
        // Judge identity and status immutable during ruling
        && request.resource.data.judgeId == resource.data.judgeId
        && request.resource.data.judgeStatus == resource.data.judgeStatus
        // currentTurn must be one of the two players after the ruling
        && (
          request.resource.data.currentTurn == resource.data.player1Uid ||
          request.resource.data.currentTurn == resource.data.player2Uid
        )
        // turnDeadline must be a timestamp bounded to a sane future window
        // (see create rule for rationale on the 48h cap).
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        && request.resource.data.turnDeadline < request.time + duration.value(48, 'h')
        // Letters: accept (no change) or dispute (one player +1)
        && (
          (request.resource.data.p1Letters == resource.data.p1Letters
           && request.resource.data.p2Letters == resource.data.p2Letters)
          || (request.resource.data.p1Letters == resource.data.p1Letters + 1
              && request.resource.data.p2Letters == resource.data.p2Letters)
          || (request.resource.data.p1Letters == resource.data.p1Letters
              && request.resource.data.p2Letters == resource.data.p2Letters + 1)
        )
        // Must resolve to setting (continue) or complete (game over).
        // Completion path pins winner direction (see match-resolution rule
        // for rationale) — judge-overruled dispute that pushes a player to
        // their 5th letter must record the OTHER player as winner.
        && (
          (request.resource.data.status == 'active'
           && request.resource.data.phase == 'setting'
           && request.resource.data.winner == null)
          || (request.resource.data.status == 'complete'
              && request.resource.data.winner != null
              && (
                (request.resource.data.p1Letters >= 5
                 && request.resource.data.winner == resource.data.player2Uid)
                || (request.resource.data.p2Letters >= 5
                    && request.resource.data.winner == resource.data.player1Uid)
              ))
        )
        // turnHistory growth bound — judge rulings append a single
        // TurnRecord with judgedBy set. Same 1-per-write + ≤200 ceiling
        // the match-resolution branch enforces.
        && turnHistoryGrowthOk();

      // ── Call BS resolution (judge rules on set trick in setReview phase) ──
      // Judge-only. Clean → back to matching (matcher must attempt).
      // Sketchy → back to setting (same setter re-sets, trick fields cleared).
      // No letter changes, no game completion.
      allow update: if isSignedIn()
        && isJudge(resource.data)
        && resource.data.status == 'active'
        && resource.data.phase == 'setReview'
        && request.auth.uid == resource.data.currentTurn
        && judgeActive(resource.data)
        // Rate limit. New updatedAt must equal request.time so the 2s
        // cooldown can't be defeated by writing a stale value on each turn.
        && 'updatedAt' in request.resource.data
        && request.resource.data.updatedAt == request.time
        && (
          !('updatedAt' in resource.data)
          || resource.data.updatedAt == null
          || request.time > resource.data.updatedAt + duration.value(2, 's')
        )
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        && (
          (!('spotId' in resource.data) && !('spotId' in request.resource.data))
          || ('spotId' in resource.data && 'spotId' in request.resource.data
              && request.resource.data.spotId == resource.data.spotId)
        )
        && request.resource.data.judgeId == resource.data.judgeId
        && request.resource.data.judgeStatus == resource.data.judgeStatus
        && request.resource.data.status == 'active'
        && request.resource.data.winner == null
        // turnDeadline must be a timestamp bounded to a sane future window
        // (see create rule for rationale on the 48h cap).
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        && request.resource.data.turnDeadline < request.time + duration.value(48, 'h')
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        && request.resource.data.currentSetter == resource.data.currentSetter
        // Clean: back to matching with matcher's turn.
        // Sketchy: back to setting with same setter re-setting.
        && (
          (request.resource.data.phase == 'matching'
           && request.resource.data.currentTurn == opponentUid(resource.data, resource.data.currentSetter))
          || (request.resource.data.phase == 'setting'
              && request.resource.data.currentTurn == resource.data.currentSetter
              && request.resource.data.currentTrickName == null
              && request.resource.data.currentTrickVideoUrl == null)
        )
        // turnHistory growth bound — Call BS rulings that go "sketchy"
        // append a TurnRecord noting the invalidated set. Same cap as the
        // other resolution branches.
        && turnHistoryGrowthOk();

      // ── Judge invite accept / decline ──
      // Only the nominated judge can flip their status from pending. No
      // other field may change on the same write.
      allow update: if isSignedIn()
        && isJudge(resource.data)
        && resource.data.status == 'active'
        && 'judgeStatus' in resource.data
        && resource.data.judgeStatus == 'pending'
        && request.resource.data.judgeId == resource.data.judgeId
        // Re-verify judge isn't either player — defence-in-depth in case the
        // create-time check was bypassed (e.g. older docs written before the
        // check was added). Without this an account that is somehow set as
        // both player and judge could accept their own dispute.
        && resource.data.judgeId != resource.data.player1Uid
        && resource.data.judgeId != resource.data.player2Uid
        && (request.resource.data.judgeStatus == 'accepted'
            || request.resource.data.judgeStatus == 'declined')
        // Everything else must stay identical.
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        && request.resource.data.status == resource.data.status
        && request.resource.data.phase == resource.data.phase
        && request.resource.data.currentTurn == resource.data.currentTurn
        && request.resource.data.currentSetter == resource.data.currentSetter
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        && request.resource.data.winner == resource.data.winner
        && request.resource.data.turnNumber == resource.data.turnNumber
        && (
          (!('turnHistory' in resource.data) && !('turnHistory' in request.resource.data))
          || request.resource.data.turnHistory == resource.data.turnHistory
        );

      // Either player can forfeit the current-turn player's expired turn
      // Winner must be the opponent of the player whose turn it is
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && request.resource.data.status == 'forfeit'
        // Only forfeit from setting or matching (disputable auto-accepts,
        // setReview auto-clears to matching — neither is a forfeit path).
        && (resource.data.phase == 'setting' || resource.data.phase == 'matching')
        // Turn deadline must have actually expired (prevents premature forfeits)
        && request.time > resource.data.turnDeadline
        // Cannot change player UIDs, usernames, or letters
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        // spotId is immutable after creation — a forfeit must not change it.
        && (
          (!('spotId' in resource.data) && !('spotId' in request.resource.data))
          || ('spotId' in resource.data && 'spotId' in request.resource.data
              && request.resource.data.spotId == resource.data.spotId)
        )
        // Winner must be the opponent of the current-turn player (who timed out)
        && request.resource.data.winner == opponentUid(resource.data, resource.data.currentTurn)
        // turnHistory must not change during a forfeit (and cannot be injected if absent)
        && (
          (!('turnHistory' in resource.data) && !('turnHistory' in request.resource.data))
          || request.resource.data.turnHistory == resource.data.turnHistory
        );

      // ── Expired dispute auto-accept ──
      // When the judge's review window expires (24 h), any participant
      // (player or judge) can trigger auto-accept: matcher's "landed" call
      // stands, roles swap, no letters change, game continues.
      allow update: if isSignedIn()
        && isParticipant(resource.data)
        && resource.data.status == 'active'
        && resource.data.phase == 'disputable'
        && request.time > resource.data.turnDeadline
        // Letters must not change (auto-accept = landed)
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        // Cannot change player UIDs or usernames
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        // spotId + judge immutable
        && (
          (!('spotId' in resource.data) && !('spotId' in request.resource.data))
          || ('spotId' in resource.data && 'spotId' in request.resource.data
              && request.resource.data.spotId == resource.data.spotId)
        )
        && request.resource.data.judgeId == resource.data.judgeId
        && request.resource.data.judgeStatus == resource.data.judgeStatus
        // Must transition back to setting (active, no winner)
        && request.resource.data.status == 'active'
        && request.resource.data.phase == 'setting'
        && request.resource.data.winner == null
        // turnDeadline must be a fresh, bounded future timestamp. This path
        // fires only after the OLD deadline expired, but the NEW deadline
        // written here is what governs the next turn — so it needs the same
        // 48h cap every other write path enforces.
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        && request.resource.data.turnDeadline < request.time + duration.value(48, 'h')
        // turnHistory growth bound — auto-accept writes a TurnRecord for
        // the expired dispute. Same 1-per-write + ≤200 ceiling.
        && turnHistoryGrowthOk();

      // ── Expired setReview auto-clear ──
      // When the judge doesn't rule on a "Call BS" within 24h, the set
      // stands (benefit of the doubt) and matcher is prompted to attempt.
      allow update: if isSignedIn()
        && isParticipant(resource.data)
        && resource.data.status == 'active'
        && resource.data.phase == 'setReview'
        && request.time > resource.data.turnDeadline
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        && (
          (!('spotId' in resource.data) && !('spotId' in request.resource.data))
          || ('spotId' in resource.data && 'spotId' in request.resource.data
              && request.resource.data.spotId == resource.data.spotId)
        )
        && request.resource.data.judgeId == resource.data.judgeId
        && request.resource.data.judgeStatus == resource.data.judgeStatus
        && request.resource.data.status == 'active'
        && request.resource.data.phase == 'matching'
        && request.resource.data.winner == null
        && request.resource.data.currentSetter == resource.data.currentSetter
        && request.resource.data.currentTurn == opponentUid(resource.data, resource.data.currentSetter)
        // turnDeadline must be a fresh, bounded future timestamp. Same
        // rationale as the expired-dispute auto-accept above.
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        && request.resource.data.turnDeadline < request.time + duration.value(48, 'h')
        // turnHistory growth bound — this path typically leaves the
        // history unchanged (no new turn was completed), but we still run
        // the helper to enforce the absolute 200-entry ceiling and block
        // any sneaky append.
        && turnHistoryGrowthOk();

      // Players may delete their own non-active games (account deletion flow)
      allow delete: if isSignedIn() && isPlayer(resource.data)
        && resource.data.status != "active";
    }

    // ── Spots ──
    // User-contributed skate spots. The map feature lives entirely on
    // Firestore per charter 2.2 ("no custom backend — Firebase rules are
    // the authorization layer"). Spots are world-readable for any signed-
    // in user; only email-verified users can create them; creators can
    // only update their own spots and cannot change immutable fields
    // (coordinates, createdBy, isVerified, isActive) after creation.
    match /spots/{spotId} {
      // Active spots are readable only by signed-in users. Requiring auth
      // closes the anonymous-scraping attack surface: without it, any drive-
      // by attacker could enumerate every spot + join with clips + users to
      // build a user-location graph (privacy incident + App-Store location-
      // data disclosure exposure). Inactive (soft-deleted or moderation-
      // hidden) spots remain unreadable by anyone through this rule. All
      // write paths below remain auth-gated (unchanged).
      //
      // NOTE: the SpotMap / SpotDetailPage screens are accessed from within
      // the app after auth — there are no public unauth reads in the client
      // (verified by grep over src/services/spots.ts + screens/SpotDetailPage).
      // Deep-links to /spots/:id land on the sign-in gate first when called
      // by a signed-out user.
      allow read: if isSignedIn() && resource.data.isActive == true;

      // Create: signed-in + email-verified, owner-stamped, with full
      // field validation mirroring the shared Spot type. Rate-limited
      // via users/{uid}.lastSpotCreatedAt (30s cooldown), same pattern
      // as game creation above.
      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.createdBy == request.auth.uid
        // name: 1–80 chars
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        // description: optional, ≤500 chars
        && (
          request.resource.data.description == null
          || (request.resource.data.description is string
              && request.resource.data.description.size() <= 500)
        )
        // latitude/longitude: finite numbers in WGS84 range
        && request.resource.data.latitude is number
        && request.resource.data.latitude >= -90
        && request.resource.data.latitude <= 90
        && request.resource.data.longitude is number
        && request.resource.data.longitude >= -180
        && request.resource.data.longitude <= 180
        // ratings: integer 1–5
        && request.resource.data.gnarRating is int
        && request.resource.data.gnarRating >= 1
        && request.resource.data.gnarRating <= 5
        && request.resource.data.bustRisk is int
        && request.resource.data.bustRisk >= 1
        && request.resource.data.bustRisk <= 5
        // obstacles: list, ≤14 items (one per obstacle type)
        && request.resource.data.obstacles is list
        && request.resource.data.obstacles.size() <= 14
        // photoUrls: list, max 5
        && request.resource.data.photoUrls is list
        && request.resource.data.photoUrls.size() <= 5
        // Verified and active flags: clients cannot self-verify; active
        // must start true (soft-delete is an update, not a create).
        && request.resource.data.isVerified == false
        && request.resource.data.isActive == true
        // Rate limit: at most one spot creation per 30 seconds per user.
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || !('lastSpotCreatedAt' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
          || request.time > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastSpotCreatedAt + duration.value(30, 's')
        );

      // Update: owner-only, and coordinates + ownership + verification +
      // active flag are immutable after creation (soft-delete goes through
      // a separate admin flow, not covered here).
      allow update: if isSignedIn()
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.latitude == resource.data.latitude
        && request.resource.data.longitude == resource.data.longitude
        && request.resource.data.isVerified == resource.data.isVerified
        && request.resource.data.isActive == resource.data.isActive
        // Mutable fields still get type-checked.
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        && (
          request.resource.data.description == null
          || (request.resource.data.description is string
              && request.resource.data.description.size() <= 500)
        )
        // Re-apply the same validation block that `create` uses for the
        // remaining mutable fields. Without this, an owner could submit
        // out-of-range ratings, oversized obstacle/photo lists, or wrong
        // types via a direct API call and bypass the create-time guards.
        && request.resource.data.gnarRating is int
        && request.resource.data.gnarRating >= 1
        && request.resource.data.gnarRating <= 5
        && request.resource.data.bustRisk is int
        && request.resource.data.bustRisk >= 1
        && request.resource.data.bustRisk <= 5
        && request.resource.data.obstacles is list
        && request.resource.data.obstacles.size() <= 14
        && request.resource.data.photoUrls is list
        && request.resource.data.photoUrls.size() <= 5;

      // Delete: owner only. (Prefer soft-delete via admin in practice.)
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      // ── Spot comments (subcollection) ──
      match /comments/{commentId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.auth.token.email_verified == true
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() >= 1
          && request.resource.data.content.size() <= 300;

        // Comments are immutable once posted — no edits, only owner delete.
        allow update: if false;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // ── Nudges ──
    // A nudge is a push-notification poke sent to an idle opponent.
    match /nudges/{nudgeId} {
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.gameId is string
        && request.resource.data.senderUsername is string
        && request.resource.data.delivered == false
        // Sender must be a player in the game, recipient must be the other player
        && (
          (request.auth.uid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player1Uid
           && request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player2Uid)
          ||
          (request.auth.uid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player2Uid
           && request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player1Uid)
        )
        // Only nudge active games
        && get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.status == 'active'
        // Companion-write requirement (May 2026 H1 hardening): in the same
        // batch the sender MUST also write nudge_limits/{senderUid_gameId}
        // with lastNudgedAt pinned to request.time. Without this, the client
        // could write /nudges and skip the rate-limit doc — defeating the
        // 1-hour cooldown server-side. getAfter() reflects the post-batch
        // state, so a missing limit write means the doc isn't there and
        // the rule rejects. Mirrors the /reports pattern (H-R2).
        && getAfter(/databases/$(database)/documents/nudge_limits/$(request.auth.uid + '_' + request.resource.data.gameId)).data.lastNudgedAt == request.time;

      // Only the Admin SDK (Cloud Function) can update delivered status
      allow update: if false;

      // Sender or recipient can read nudges
      allow read: if isSignedIn()
        && (resource.data.senderUid == request.auth.uid
            || resource.data.recipientUid == request.auth.uid);

      allow delete: if false;
    }

    // ── Billing alerts (server-only) ──
    // Historically written by the onBillingAlert Cloud Function (removed).
    // No client access; retained so any future external consumer writing
    // here (via Admin SDK) stays locked down to clients.
    match /billingAlerts/{alertId} {
      allow read, write: if false;
    }

    // ── Notifications (in-app alerts for game events) ──
    // Written by the client when a game action occurs (e.g. your turn, challenge).
    // Only the recipient can read their own notifications.
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.type in ['your_turn', 'new_challenge', 'game_won', 'game_lost', 'judge_invite']
        && request.resource.data.title is string
        // Hard cap on user-visible strings — prevents a malicious sender from
        // wedging multi-megabyte notification docs into the recipient's feed.
        && request.resource.data.title.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 200
        && request.resource.data.gameId is string
        && request.resource.data.read == false
        && request.resource.data.createdAt == request.time
        // Sender must be a participant (player OR judge) of the referenced game.
        && isParticipant(get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data)
        // Recipient must be a participant (player OR judge) of the same game.
        // Allows: player→player (existing), player→judge (judge_invite),
        // judge→player (your_turn after ruling).
        && (
          request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player1Uid
          || request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player2Uid
          || (
            'judgeId' in get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data
            && get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.judgeId != null
            && request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.judgeId
          )
        )
        // Rate limit: at most 1 notification per game per action type per 5 seconds
        && (
          !exists(/databases/$(database)/documents/notification_limits/$(request.auth.uid + '_' + request.resource.data.gameId + '_' + request.resource.data.type))
          || request.time > get(/databases/$(database)/documents/notification_limits/$(request.auth.uid + '_' + request.resource.data.gameId + '_' + request.resource.data.type)).data.lastSentAt + duration.value(5, 's')
        )
        // Companion-write requirement (May 2026 H2 hardening): a /notifications
        // create must commit ATOMICALLY with one of two anchors so a malicious
        // client can't write /notifications and skip the cooldown bookkeeping
        // (or, worse, omit it entirely and spam an opponent's feed).
        //
        //   Path A — standalone (writeNotification): the same batch must write
        //   notification_limits/{senderUid_gameId_type} with lastSentAt pinned
        //   to request.time. Mirrors the /reports + /nudges companion-write
        //   pattern, and refreshes the 5s cooldown anchor in lockstep with
        //   the notification.
        //
        //   Path B — in-tx (writeNotificationInTx): the notification is part
        //   of a runTransaction that also updates /games/{gameId} with
        //   updatedAt = serverTimestamp() (i.e. request.time). Every game
        //   action that emits an in-tx notification already does this, and
        //   game writes are themselves rate-limited (turn-action 2s
        //   server cooldown + turn-order rules), so we don't need a second
        //   limits doc on the in-tx hot path.
        //
        // getAfter() reflects the post-commit state; if neither anchor lands
        // in the same batch the rule rejects.
        && (
          getAfter(/databases/$(database)/documents/notification_limits/$(request.auth.uid + '_' + request.resource.data.gameId + '_' + request.resource.data.type)).data.lastSentAt == request.time
          || getAfter(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.updatedAt == request.time
        );

      // Only the recipient can mark a notification as read
      allow update: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.read == true
        // Cannot change other fields
        && request.resource.data.recipientUid == resource.data.recipientUid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.type == resource.data.type
        && request.resource.data.title == resource.data.title
        && request.resource.data.body == resource.data.body
        && request.resource.data.gameId == resource.data.gameId
        && request.resource.data.createdAt == resource.data.createdAt;

      // Only the recipient can delete their own notifications.
      allow delete: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid;
    }

    // ── Notification rate limits ──
    // One doc per sender+game+type combo, enforces 5-second cooldown server-side.
    match /notification_limits/{limitId} {
      // NOTE: Clients only write to this collection (setDoc). If a future
      // read path is added, handle the non-existent-doc case (resource == null).
      allow read: if isSignedIn()
        && resource.data.senderUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.senderUid
        && limitId == (request.auth.uid + '_' + request.resource.data.gameId + '_' + request.resource.data.type)
        && request.resource.data.type in ['your_turn', 'new_challenge', 'game_won', 'game_lost', 'judge_invite']
        // lastSentAt must equal the server's current time. Without this, a
        // client could seed the doc with a stale timestamp (e.g. epoch 0)
        // and every subsequent update would instantly satisfy the 5s cooldown
        // below, defeating server-side notification rate limiting.
        && request.resource.data.lastSentAt == request.time;

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.senderUid
        && request.time > resource.data.lastSentAt + duration.value(5, 's')
        // New lastSentAt must equal the server's current time — i.e. the
        // client wrote serverTimestamp(). The previous rule accepted any
        // new value, so a malicious client could back-date lastSentAt on
        // each write and keep the 5s cooldown permanently satisfied.
        && request.resource.data.lastSentAt == request.time
        // Immutable identity fields: the doc id is derived from
        // senderUid + gameId + type, so mutating any of them would desync
        // the cooldown key from its bucket and let a sender silently
        // rewrite another bucket's cooldown state.
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.gameId == resource.data.gameId
        && request.resource.data.type == resource.data.type;

      // Rate-limit docs are server-managed cooldown state with no user-facing
      // lifecycle. Clients must never delete them — a successful delete would
      // reset the 5-second cooldown and let a sender spam notifications.
      // (The previous rule checked resource.data.recipientUid, which doesn't
      // exist on these docs — so it was a copy-paste from /notifications that
      // always denied. Making the intent explicit matches /nudge_limits.)
      allow delete: if false;
    }

    // ── Push targets (cross-readable token mirror) ──
    // The canonical FCM token list lives at users/{uid}/private/profile
    // .fcmTokens (owner-only). This mirror exposes the same tokens to any
    // signed-in user so a SENDER (game opponent / nominated judge) can
    // embed them into a /push_dispatch doc — the Firebase Extension that
    // dispatches background push reads `tokens` from each dispatch doc.
    //
    // Why cross-readable is bounded risk: FCM tokens alone cannot be turned
    // into a push attack — the FCM HTTP API requires OAuth2 with the
    // project's service account, which only the Extension (running as
    // Admin SDK) has. A leaked token can be paired with a uid (privacy
    // leak surface) but cannot be abused for push spam by another
    // authenticated user. The /push_dispatch create rule below additionally
    // requires the sender to be a game participant AND requires
    // `tokens.hasOnly(<mirror>)` so a sender cannot inject bogus tokens to
    // misroute pushes.
    //
    // Cap mirrors the canonical fcmTokens cap (≤10) — keeps fan-out bounded
    // even when a user is signed in on every device they own.
    match /pushTargets/{uid} {
      allow read: if isSignedIn();

      // Allowlist of accepted keys. setDoc(..., merge:true) is the only
      // legitimate writer (src/services/fcm.ts + pushNotifications.ts), and
      // every write touches both fields together — keep this in lockstep
      // with the writers if you add a field.
      function pushTargetsKeysOk() {
        return request.resource.data.keys().hasOnly(['tokens', 'updatedAt']);
      }

      function pushTargetsShapeOk() {
        return request.resource.data.tokens is list
          && request.resource.data.tokens.size() <= 10
          // updatedAt MUST equal server time — without this, a client could
          // backfill an old timestamp and we'd lose stale-token-cleanup
          // semantics elsewhere (the Extension uses updatedAt to skip
          // long-revoked mirrors when a delivery attempt 404s).
          && request.resource.data.updatedAt == request.time;
      }

      allow create: if isOwner(uid)
        && pushTargetsKeysOk()
        && pushTargetsShapeOk();
      allow update: if isOwner(uid)
        && pushTargetsKeysOk()
        && pushTargetsShapeOk();
      // Owner may wipe their mirror (e.g. on account deletion).
      allow delete: if isOwner(uid);
    }

    // ── Push dispatch (Firebase Extension trigger collection) ──
    // The `firebase/firestore-send-fcm` Extension watches this collection
    // (configured in extensions/firestore-send-fcm.env) and forwards each
    // created doc to the FCM HTTP API. The extension runs as Admin SDK so
    // it bypasses these rules — they only gate CLIENT writes to keep
    // attackers from spamming the FCM API via injected dispatch docs.
    //
    // Why this collection exists: client-side dispatch is the only way to
    // wake offline recipients without a Cloud Function (which the
    // verify-no-cloud-functions CI gate blocks). The Extension is a managed
    // deployment outside functions/src/, so it slips past the gate cleanly.
    //
    // Anti-abuse posture:
    //  1. Sender must be a signed-in game participant
    //  2. Recipient must be a participant of the same game (player or judge)
    //  3. tokens.hasOnly(<recipient's mirror>) — no token injection
    //  4. Title/body caps mirror /notifications (≤80 / ≤200) to bound payload
    //  5. Rate anchor: a fresh /notification_limits or /games update by the
    //     SAME sender for the SAME (game, type) must exist within 10s.
    //     Transfers /notifications' 5s rate limit to /push_dispatch by
    //     reference — a client cannot dispatch faster than they can
    //     legitimately notify.
    //
    // The 10s window (vs the notification's 5s) absorbs the network gap
    // between /notifications commit and /push_dispatch commit. Both anchors
    // are committed BEFORE this rule evaluates, so get() (not getAfter)
    // is the right primitive.
    match /push_dispatch/{dispatchId} {
      // Read: only sender and recipient. The Extension reads via Admin SDK
      // so it ignores these rules. Recipient access lets a debug UI show
      // "delivery pending" state without exposing dispatch payloads
      // cross-user.
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.senderUid
            || request.auth.uid == resource.data.recipientUid);

      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.gameId is string
        && request.resource.data.type in ['your_turn', 'new_challenge', 'game_won', 'game_lost', 'judge_invite']
        // ── Extension payload shape ──
        && request.resource.data.notification is map
        && request.resource.data.notification.title is string
        && request.resource.data.notification.title.size() <= 80
        && request.resource.data.notification.body is string
        && request.resource.data.notification.body.size() <= 200
        && request.resource.data.data is map
        && request.resource.data.data.gameId == request.resource.data.gameId
        // ── Tokens ──
        && request.resource.data.tokens is list
        && request.resource.data.tokens.size() >= 1
        && request.resource.data.tokens.size() <= 10
        && request.resource.data.createdAt == request.time
        // ── Participation ──
        // Sender must be a participant (player OR judge) of the referenced game.
        && isParticipant(get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data)
        // Recipient must be a participant of the same game. Mirrors the
        // /notifications create rule — player→player (your_turn / game_*),
        // player→judge (judge_invite, ruling needed), judge→player (rulings).
        && (
          request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player1Uid
          || request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player2Uid
          || (
            'judgeId' in get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data
            && get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.judgeId != null
            && request.resource.data.recipientUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.judgeId
          )
        )
        // ── Token integrity ──
        // Every token MUST appear in the recipient's /pushTargets mirror.
        // Without this, a malicious sender could embed arbitrary tokens
        // (their own device, a token scraped from another collection, …)
        // and have the Extension deliver pushes to wrong devices.
        // hasOnly is the inverse of hasAll: it checks subset, which is
        // what we want — sender's tokens ⊆ recipient's mirror.
        && request.resource.data.tokens.hasOnly(
          get(/databases/$(database)/documents/pushTargets/$(request.resource.data.recipientUid)).data.tokens
        )
        // ── Rate-limit anchor ──
        // Threads the /notifications 5s cooldown onto /push_dispatch.
        // Either branch proves the sender legitimately emitted a
        // notification (best-effort or in-tx path) within the last 10s.
        && (
          (
            exists(/databases/$(database)/documents/notification_limits/$(request.auth.uid + '_' + request.resource.data.gameId + '_' + request.resource.data.type))
            && get(/databases/$(database)/documents/notification_limits/$(request.auth.uid + '_' + request.resource.data.gameId + '_' + request.resource.data.type)).data.lastSentAt > request.time - duration.value(10, 's')
          )
          || get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.updatedAt > request.time - duration.value(10, 's')
        );

      // Dispatch docs are immutable once created — the Extension writes its
      // delivery results to a sibling collection (configured by the
      // Extension), so clients never need to update or delete here. The
      // Extension's worker runs as Admin SDK and ignores these rules for
      // its own bookkeeping writes.
      allow update: if false;
      allow delete: if false;
    }

    // ── Reports (content/player flagging for Google Play UGC policy) ──
    // Users can report opponents in games they participate in. The previous
    // rule leaned on a client-side "query + check" comment to enforce
    // uniqueness; that's harassment-vector and moderator-queue-DoS bait.
    // Server-side rate limit: one report per (reporter, reported) pair per
    // 1 hour, enforced by requiring a companion write to
    // `reports_limits/{reporterUid}_{reportedUid}` in the SAME batch.
    // (That caps the worst case at 24 reports/day against a single target
    // per reporter — fine for moderation triage; no per-day counter needed.)
    //
    // Reports are immutable once created (only Admin SDK can update status).
    match /reports/{reportId} {
      // Only the reporter can read their own reports (to check for duplicates)
      allow read: if isSignedIn()
        && resource.data.reporterUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        // Cannot report yourself
        && request.resource.data.reportedUid != request.auth.uid
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUsername is string
        && request.resource.data.gameId is string
        && request.resource.data.reason is string
        && request.resource.data.reason in ['inappropriate_video', 'abusive_behavior', 'cheating', 'spam', 'other']
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.status == 'pending'
        // Optional clipId: when a report targets a clip from the feed rather
        // than an in-game video, it carries the clip's deterministic id
        // (`${gameId}_${turnNumber}_${role}`). Shape-only check here —
        // moderators dedupe and action via Admin SDK.
        && (
          !('clipId' in request.resource.data)
          || (request.resource.data.clipId is string
              && request.resource.data.clipId.size() > 0
              && request.resource.data.clipId.size() <= 128)
        )
        // Rate-limit gate: EITHER the reporter has never reported this
        // target before (no limits doc exists) OR the previous report was
        // more than 1 hour ago. Checked against the PRE-batch state via
        // get(); getAfter() below covers the companion-write freshness.
        && (
          !exists(/databases/$(database)/documents/reports_limits/$(request.auth.uid + '_' + request.resource.data.reportedUid))
          || request.time > get(/databases/$(database)/documents/reports_limits/$(request.auth.uid + '_' + request.resource.data.reportedUid)).data.lastSentAt + duration.value(1, 'h')
        )
        // Companion-write requirement: in the same batch, the reporter MUST
        // also write the matching reports_limits/{reporter_reported} doc
        // with lastSentAt pinned to request.time. Without this, the
        // cooldown would never advance. getAfter() reflects the batch's
        // post-commit state — if the client didn't include the limit
        // write, the doc won't exist there and the rule rejects.
        && getAfter(/databases/$(database)/documents/reports_limits/$(request.auth.uid + '_' + request.resource.data.reportedUid)).data.lastSentAt == request.time;

      // Reports are immutable — only Admin SDK can update (for moderation)
      allow update: if false;
      allow delete: if false;
    }

    // ── Report rate limits ──
    // One doc per (reporter, reported) pair, enforces 1-hour cooldown
    // server-side. Companion write to every /reports create (see above).
    // Mirrors nudge_limits / notification_limits: lastSentAt is pinned to
    // request.time on every create/update to close the back-date bypass
    // where a client seeds epoch 0 and permanently satisfies the gate.
    match /reports_limits/{limitId} {
      // NOTE: Clients only write to this collection. If a future read path
      // is added, handle the non-existent-doc case (resource == null).
      allow read: if isSignedIn()
        && resource.data.reporterUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.reporterUid
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUid != request.auth.uid
        // Doc id MUST be the deterministic `${reporterUid}_${reportedUid}`
        // so the /reports create rule can look it up by shape.
        && limitId == (request.auth.uid + '_' + request.resource.data.reportedUid)
        // lastSentAt pinned to server time. Any other value lets a client
        // back-date the cooldown anchor and keep the 1h gate permanently
        // satisfied. Same pattern as nudge_limits.lastNudgedAt.
        && request.resource.data.lastSentAt == request.time;

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.reporterUid
        // 1-hour cooldown vs the stored anchor.
        && request.time > resource.data.lastSentAt + duration.value(1, 'h')
        // New lastSentAt must be server time — closes the same back-date
        // bypass on updates as the create rule above.
        && request.resource.data.lastSentAt == request.time
        // Immutable identity fields: the doc id is derived from
        // reporterUid + reportedUid, so mutating either would desync the
        // cooldown key from its bucket and let a reporter silently rewrite
        // another pair's cooldown state.
        && request.resource.data.reporterUid == resource.data.reporterUid
        && request.resource.data.reportedUid == resource.data.reportedUid;

      // Rate-limit docs are server-managed cooldown state with no user-
      // facing lifecycle. Clients must never delete them — a successful
      // delete would reset the 1h cooldown and re-enable spam.
      allow delete: if false;
    }

    // ── Nudge rate limits ──
    // One doc per sender+game pair, enforces 1-hour cooldown server-side.
    match /nudge_limits/{limitId} {
      // NOTE: Clients only write to this collection (setDoc). If a future
      // read path is added, handle the non-existent-doc case (resource == null).
      allow read: if isSignedIn()
        && resource.data.senderUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.senderUid
        && limitId == (request.auth.uid + '_' + request.resource.data.gameId)
        // lastNudgedAt must equal the server's current time. Otherwise a
        // client could seed the doc with an ancient timestamp, bypassing
        // the 1-hour cooldown on every subsequent update forever.
        && request.resource.data.lastNudgedAt == request.time;

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.senderUid
        && request.time > resource.data.lastNudgedAt + duration.value(1, 'h')
        // New lastNudgedAt must equal the server's current time — prevents
        // the same back-dating bypass on updates (see create rule above).
        && request.resource.data.lastNudgedAt == request.time
        // Immutable identity fields: the doc id is senderUid + gameId, so
        // mutating either would cross-pollute cooldowns across buckets.
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.gameId == resource.data.gameId;

      allow delete: if false;
    }

    // ── Clips (landed-trick feed) ──
    // Denormalized from games.turnHistory, written atomically inside the same
    // runTransaction that appends the TurnRecord (see src/services/clips.ts
    // writeLandedClipsInTransaction). Each landed turn can produce up to two
    // clips: `set` (setter's landed set) and `match` (matcher's landed match,
    // only when they actually landed it).
    //
    // Integrity rests on four constraints:
    //   1. Deterministic doc id `${gameId}_${turnNumber}_${role}` — idempotent
    //      under transaction retry and prevents duplicates.
    //   2. Writer must be a participant of the referenced game (verified via
    //      get() against the game doc), matching the write privileges that
    //      already govern turnHistory growth.
    //   3. Create sets moderationStatus == 'active' and cannot be updated by
    //      clients — transitions to 'hidden' happen via Admin SDK in response
    //      to a user report (App Store Guideline 1.2 moderation requirement).
    //   4. Owner (playerUid) can delete their own clip — closes the GDPR /
    //      CCPA right-to-erasure loop from the account-deletion flow.
    //
    // Reads are open to any signed-in user: blocklist filtering is applied
    // client-side (see useBlockedUsers), matching how the rest of the app
    // handles cross-user content.
    match /clips/{clipId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        // Deterministic id must match the clip's self-described coordinates.
        && clipId == (request.resource.data.gameId + '_'
                      + string(request.resource.data.turnNumber) + '_'
                      + request.resource.data.role)
        && request.resource.data.gameId is string
        && request.resource.data.turnNumber is int
        && request.resource.data.turnNumber > 0
        && request.resource.data.role in ['set', 'match']
        && request.resource.data.playerUid is string
        && request.resource.data.playerUsername is string
        && request.resource.data.playerUsername.size() > 0
        && request.resource.data.playerUsername.size() <= 20
        && request.resource.data.trickName is string
        && request.resource.data.trickName.size() > 0
        && request.resource.data.trickName.size() <= 100
        && request.resource.data.videoUrl is string
        && request.resource.data.videoUrl.size() > 0
        && request.resource.data.videoUrl.size() <= 2048
        && (request.resource.data.spotId == null
            || (request.resource.data.spotId is string
                && request.resource.data.spotId.size() <= 64))
        && request.resource.data.createdAt == request.time
        // Moderation status must start as 'active'. Transitions to 'hidden'
        // are server-side only (Admin SDK), keeping the App Store takedown
        // path out of client reach.
        && request.resource.data.moderationStatus == 'active'
        // upvoteCount aggregate must seed at 0; client-side ranking reads
        // this field directly so it has to start at the empty state.
        && request.resource.data.upvoteCount == 0
        // Writer must be a game participant (player OR nominated judge).
        && isParticipant(get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data)
        // playerUid must be one of the game's two players — never the judge,
        // never an arbitrary UID.
        && (
          request.resource.data.playerUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player1Uid
          || request.resource.data.playerUid == get(/databases/$(database)/documents/games/$(request.resource.data.gameId)).data.player2Uid
        );

      // Clips are otherwise immutable once written — content edits and
      // moderation flips both go through Admin SDK to keep the audit trail
      // clean. The narrow exception is the `upvoteCount` aggregate, which
      // a signed-in user can adjust by ±1 ONLY when paired with the
      // corresponding clipVotes/{uid}_{clipId} create or delete in the
      // same atomic write (see src/services/clips.ts → upvoteClip). The
      // existsAfter() / !existsAfter() checks bind the count delta to the
      // post-transaction state of the vote doc, so a client cannot inflate
      // the count without also creating its vote doc, and cannot deflate
      // the count without also deleting it.
      allow update: if isSignedIn()
        && request.auth.token.email_verified == true
        // Only upvoteCount is allowed to change — every other field stays put.
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteCount'])
        && request.resource.data.upvoteCount is int
        && request.resource.data.upvoteCount >= 0
        // Legacy clips that pre-date the aggregate lack the field on disk.
        // get(field, default) treats them as 0 so a first-time upvote on a
        // pre-backfill clip isn't rejected as a permission-denied — the
        // service mapper applies the same default on read.
        && (
          // +1 path: vote doc was just created in this transaction —
          // didn't exist before AND exists after. Without the !exists()
          // guard, a client could increment the count without writing a
          // vote doc (the doc already exists from a prior upvote).
          (request.resource.data.upvoteCount == resource.data.get('upvoteCount', 0) + 1
            && !exists(/databases/$(database)/documents/clipVotes/$(request.auth.uid + '_' + clipId))
            && existsAfter(/databases/$(database)/documents/clipVotes/$(request.auth.uid + '_' + clipId)))
          ||
          // -1 path: vote doc was just deleted in this transaction —
          // existed before AND no longer exists after.
          (request.resource.data.upvoteCount == resource.data.get('upvoteCount', 0) - 1
            && exists(/databases/$(database)/documents/clipVotes/$(request.auth.uid + '_' + clipId))
            && !existsAfter(/databases/$(database)/documents/clipVotes/$(request.auth.uid + '_' + clipId)))
        );

      // The owning player (the one who actually landed the trick) can delete
      // their own clip. This backs the account-deletion cascade in
      // clips.ts#deleteUserClips and lets a user scrub a clip they no longer
      // want in the feed. Strangers, the opponent, and even the judge cannot
      // delete — only the clip's author.
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.playerUid;
    }

    // ── Clip upvotes ──
    //
    // One vote per (uid, clipId) enforced by the deterministic document id
    // (`${uid}_${clipId}`). The id is verified at create time so a client
    // cannot impersonate another user's vote. Votes are immutable:
    //
    //   - update forbidden — guarantees a single upvote cannot be silently
    //     overwritten into a different shape (spec: no undo).
    //   - delete owner-only — backs any future account-deletion cascade.
    //
    // Reads are open to signed-in users because the clips feed aggregates
    // votes via `getCountFromServer` and checks whether the current user
    // already upvoted via a direct get — both in `fetchClipUpvoteState`
    // (see src/services/clips.ts), and both require read permission on
    // the collection / doc.
    match /clipVotes/{voteId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        // Email verification mirrors every other content-producing rule
        // (games, spots, comments) — without it, throwaway accounts can
        // inflate vote counts on the public clips feed.
        && request.auth.token.email_verified == true
        && voteId == (request.auth.uid + '_' + request.resource.data.clipId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.clipId is string
        && request.resource.data.clipId.size() > 0
        && request.resource.data.clipId.size() <= 128
        && request.resource.data.createdAt == request.time
        // Vote target must exist — prevents orphaned votes on clips that
        // were deleted between client-side discovery and the write.
        && exists(/databases/$(database)/documents/clips/$(request.resource.data.clipId));

      allow update: if false;

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.uid;
    }
  }
}
