rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPlayer(game) {
      return isSignedIn() && (
        request.auth.uid == game.player1Uid ||
        request.auth.uid == game.player2Uid
      );
    }

    // ── Users ──
    // Users can read any profile (for opponent lookup)
    // Users can only write their own profile (created once)
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid)
        // One profile per UID — prevent a race condition from overwriting an existing profile
        && !exists(/databases/$(database)/documents/users/$(uid))
        && request.resource.data.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        // Enforce lowercase alphanumeric + underscore only (matches client-side normalisation)
        && request.resource.data.username.matches('[a-z0-9_]+')
        // wins/losses must start at zero if present (prevents leaderboard inflation
        // by injecting arbitrary stats at profile creation time)
        && (!('wins' in request.resource.data) || request.resource.data.wins == 0)
        && (!('losses' in request.resource.data) || request.resource.data.losses == 0);
      allow update: if isOwner(uid)
        // Cannot change username or uid after creation
        && request.resource.data.username == resource.data.username
        && request.resource.data.uid == resource.data.uid
        // Wins/losses can only increment by 0 or 1 per write.
        // When the field doesn't exist yet, only 0 or 1 is allowed
        // (the old rule's !('wins' in resource.data) branch accepted any value).
        && (
          !('wins' in request.resource.data)
          || (!('wins' in resource.data)
              && request.resource.data.wins >= 0 && request.resource.data.wins <= 1)
          || ('wins' in resource.data && (
            request.resource.data.wins == resource.data.wins
            || request.resource.data.wins == resource.data.wins + 1
          ))
        )
        && (
          !('losses' in request.resource.data)
          || (!('losses' in resource.data)
              && request.resource.data.losses >= 0 && request.resource.data.losses <= 1)
          || ('losses' in resource.data && (
            request.resource.data.losses == resource.data.losses
            || request.resource.data.losses == resource.data.losses + 1
          ))
        );
      // Users may delete their own profile (account deletion flow)
      allow delete: if isOwner(uid);
    }

    // ── Usernames (reservation docs for uniqueness) ──
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && username.size() >= 3
        && username.size() <= 20
        // Reservation key must be a valid username (lowercase alphanum + underscore)
        && username.matches('[a-z0-9_]+');
      // Cannot be updated; only the owning user can delete (account deletion flow)
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Helper: determine the opponent of a player ──
    function opponentUid(game, uid) {
      return uid == game.player1Uid ? game.player2Uid : game.player1Uid;
    }

    // ── Games ──
    match /games/{gameId} {
      // Both players can read their game
      allow read: if isSignedIn() && isPlayer(resource.data);

      // Any signed-in user with a verified email can create a game (as player1).
      // Email verification is enforced server-side here so it can't be bypassed
      // by calling the Firestore API directly (e.g. from the browser console).
      // Rate limit: user profile must have been updated > 30s ago (prevents spam creation).
      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.player1Uid == request.auth.uid
        // Prevent self-challenge: player2 must be a different account
        && request.resource.data.player2Uid != request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.p1Letters == 0
        && request.resource.data.p2Letters == 0
        && request.resource.data.turnNumber == 1
        && request.resource.data.winner == null
        // Challenger always has the first turn and sets first trick
        && request.resource.data.currentTurn == request.auth.uid
        && request.resource.data.phase == 'setting'
        && request.resource.data.currentSetter == request.auth.uid
        // turnDeadline must be a future timestamp (prevents instant-forfeit attack:
        // without this, a malicious client could set turnDeadline in the past,
        // currentTurn to the opponent, and immediately forfeit them)
        && request.resource.data.turnDeadline is timestamp
        && request.resource.data.turnDeadline > request.time
        // Trick/video fields must start empty
        && request.resource.data.currentTrickName == null
        && request.resource.data.currentTrickVideoUrl == null
        && request.resource.data.matchVideoUrl == null
        // Rate limit: at most one game creation per 30 seconds per user.
        // Checks the user's lastGameCreatedAt field — if it doesn't exist
        // (first game ever) the condition is satisfied automatically.
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || !('lastGameCreatedAt' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
          || request.time > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastGameCreatedAt + duration.value(30, 's')
        );

      // Current-turn player can make normal game updates
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && request.auth.uid == resource.data.currentTurn
        // Rate limit: at most one turn action per 2 seconds (prevents write flooding)
        && (
          !('updatedAt' in resource.data)
          || resource.data.updatedAt == null
          || request.time > resource.data.updatedAt + duration.value(2, 's')
        )
        // Cannot change player UIDs or usernames
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        // currentTurn must always be one of the two players after the update
        && (
          request.resource.data.currentTurn == resource.data.player1Uid ||
          request.resource.data.currentTurn == resource.data.player2Uid
        )
        // turnDeadline must be a timestamp
        && request.resource.data.turnDeadline is timestamp
        // Scores must not change during setting-phase updates.
        // Letters are only awarded via the match resolution rule below.
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        // Game stays active, no winner (completion only via match resolution or forfeit)
        && request.resource.data.status == 'active'
        && request.resource.data.winner == null
        // Valid phase transitions only (prevents skipping phases)
        && (
          // setting → matching (setter sets a trick)
          (resource.data.phase == 'setting' && request.resource.data.phase == 'matching')
          // setting → setting (setter failed to land, turn passes to opponent)
          || (resource.data.phase == 'setting' && request.resource.data.phase == 'setting')
        )
        // turnHistory must not change during setting-phase updates
        && (
          (!('turnHistory' in resource.data) && !('turnHistory' in request.resource.data))
          || request.resource.data.turnHistory == resource.data.turnHistory
        );

      // ── Match resolution (matcher self-judges: landed or missed) ──
      // The matcher resolves the turn immediately.  Letters may change and the
      // game may end, so this is a separate rule from the normal turn updates.
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && resource.data.phase == 'matching'
        && request.auth.uid == resource.data.currentTurn
        // Rate limit
        && (
          !('updatedAt' in resource.data)
          || resource.data.updatedAt == null
          || request.time > resource.data.updatedAt + duration.value(2, 's')
        )
        // Cannot change player UIDs or usernames
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        // currentTurn must be one of the two players
        && (
          request.resource.data.currentTurn == resource.data.player1Uid ||
          request.resource.data.currentTurn == resource.data.player2Uid
        )
        // turnDeadline must be a timestamp
        && request.resource.data.turnDeadline is timestamp
        // Letters: at most one player gains exactly one letter (missed) or none change (landed)
        && (
          // Landed — no letter change
          (request.resource.data.p1Letters == resource.data.p1Letters
           && request.resource.data.p2Letters == resource.data.p2Letters)
          // Missed — exactly one player gets +1
          || (request.resource.data.p1Letters == resource.data.p1Letters + 1
              && request.resource.data.p2Letters == resource.data.p2Letters)
          || (request.resource.data.p1Letters == resource.data.p1Letters
              && request.resource.data.p2Letters == resource.data.p2Letters + 1)
        )
        // Either the game continues (back to setting) or ends (complete with a winner)
        && (
          (request.resource.data.status == 'active'
           && request.resource.data.phase == 'setting'
           && request.resource.data.winner == null)
          || (request.resource.data.status == 'complete'
              && request.resource.data.winner != null)
        );

      // Either player can forfeit the current-turn player's expired turn
      // Winner must be the opponent of the player whose turn it is
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && request.resource.data.status == 'forfeit'
        // Turn deadline must have actually expired (prevents premature forfeits)
        && request.time > resource.data.turnDeadline
        // Cannot change player UIDs, usernames, or letters
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.player1Username == resource.data.player1Username
        && request.resource.data.player2Username == resource.data.player2Username
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        // Winner must be the opponent of the current-turn player (who timed out)
        && request.resource.data.winner == opponentUid(resource.data, resource.data.currentTurn)
        // turnHistory must not change during a forfeit (and cannot be injected if absent)
        && (
          (!('turnHistory' in resource.data) && !('turnHistory' in request.resource.data))
          || request.resource.data.turnHistory == resource.data.turnHistory
        );

      // Players may delete their own non-active games (account deletion flow).
      // Active games must be forfeited before deletion.
      allow delete: if isSignedIn() && isPlayer(resource.data)
        && resource.data.status != "active";
    }

    // ── Nudges ──
    // A nudge is a push-notification poke sent to an idle opponent.
    match /nudges/{nudgeId} {
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.gameId is string
        && request.resource.data.senderUsername is string
        && request.resource.data.delivered == false;

      // Only the Admin SDK (Cloud Function) can update delivered status
      allow update: if false;

      // Sender or recipient can read nudges
      allow read: if isSignedIn()
        && (resource.data.senderUid == request.auth.uid
            || resource.data.recipientUid == request.auth.uid);

      allow delete: if false;
    }

    // ── Billing alerts (server-only) ──
    // Written by the onBillingAlert Cloud Function; no client access.
    match /billingAlerts/{alertId} {
      allow read, write: if false;
    }

    // ── Notifications (in-app alerts for game events) ──
    // Written by the client when a game action occurs (e.g. your turn, challenge).
    // Only the recipient can read their own notifications.
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.recipientUid is string
        && request.resource.data.type is string
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.gameId is string
        && request.resource.data.read == false;

      // Only the recipient can mark a notification as read
      allow update: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.read == true
        // Cannot change other fields
        && request.resource.data.recipientUid == resource.data.recipientUid
        && request.resource.data.type == resource.data.type
        && request.resource.data.title == resource.data.title
        && request.resource.data.body == resource.data.body
        && request.resource.data.gameId == resource.data.gameId;

      // Recipients can delete their own notifications
      allow delete: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid;
    }

    // ── Reports (content/player flagging for Google Play UGC policy) ──
    // Users can report opponents in games they participate in.
    // Reports are immutable once created (only admins can update status).
    // Rate limit: one report per game per reporter (enforced by query + client check).
    match /reports/{reportId} {
      // Only the reporter can read their own reports (to check for duplicates)
      allow read: if isSignedIn()
        && resource.data.reporterUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        // Cannot report yourself
        && request.resource.data.reportedUid != request.auth.uid
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUsername is string
        && request.resource.data.gameId is string
        && request.resource.data.reason is string
        && request.resource.data.reason in ['inappropriate_video', 'abusive_behavior', 'cheating', 'spam', 'other']
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.status == 'pending';

      // Reports are immutable — only Admin SDK can update (for moderation)
      allow update: if false;
      allow delete: if false;
    }

    // ── Nudge rate limits ──
    // One doc per sender+game pair, enforces 1-hour cooldown server-side.
    match /nudge_limits/{limitId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.senderUid
        && limitId == (request.auth.uid + '_' + request.resource.data.gameId);

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.senderUid
        && request.time > resource.data.lastNudgedAt + duration.value(1, 'h');

      allow delete: if false;
    }
  }
}
