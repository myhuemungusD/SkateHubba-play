rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPlayer(game) {
      return isSignedIn() && (
        request.auth.uid == game.player1Uid ||
        request.auth.uid == game.player2Uid
      );
    }

    // ── Users ──
    // Users can read any profile (for opponent lookup)
    // Users can only write their own profile (created once)
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid)
        // One profile per UID — prevent a race condition from overwriting an existing profile
        && !exists(/databases/$(database)/documents/users/$(uid))
        && request.resource.data.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        // Enforce lowercase alphanumeric + underscore only (matches client-side normalisation)
        && request.resource.data.username.matches('[a-z0-9_]+');
      allow update: if isOwner(uid)
        // Cannot change username or uid after creation
        && request.resource.data.username == resource.data.username
        && request.resource.data.uid == resource.data.uid;
      // Users may delete their own profile (account deletion flow)
      allow delete: if isOwner(uid);
    }

    // ── Usernames (reservation docs for uniqueness) ──
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && username.size() >= 3
        && username.size() <= 20
        // Reservation key must be a valid username (lowercase alphanum + underscore)
        && username.matches('[a-z0-9_]+');
      // Cannot be updated; only the owning user can delete (account deletion flow)
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Helper: determine the opponent of a player ──
    function opponentUid(game, uid) {
      return uid == game.player1Uid ? game.player2Uid : game.player1Uid;
    }

    // ── Games ──
    match /games/{gameId} {
      // Both players can read their game
      allow read: if isSignedIn() && isPlayer(resource.data);

      // Any signed-in user with a verified email can create a game (as player1).
      // Email verification is enforced server-side here so it can't be bypassed
      // by calling the Firestore API directly (e.g. from the browser console).
      // Rate limit: user profile must have been updated > 30s ago (prevents spam creation).
      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.player1Uid == request.auth.uid
        // Prevent self-challenge: player2 must be a different account
        && request.resource.data.player2Uid != request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.p1Letters == 0
        && request.resource.data.p2Letters == 0
        && request.resource.data.turnNumber == 1
        && request.resource.data.winner == null
        // Rate limit: at most one game creation per 30 seconds per user.
        // Checks the user's lastGameCreatedAt field — if it doesn't exist
        // (first game ever) the condition is satisfied automatically.
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || !('lastGameCreatedAt' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
          || request.time > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastGameCreatedAt + duration.value(30, 's')
        );

      // Current-turn player can make normal game updates
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && request.auth.uid == resource.data.currentTurn
        // Cannot change player UIDs
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        // currentTurn must always be one of the two players after the update
        && (
          request.resource.data.currentTurn == resource.data.player1Uid ||
          request.resource.data.currentTurn == resource.data.player2Uid
        )
        // Scores never decrease; at most ONE player gains a letter per update
        // (prevents double-incrementing and score manipulation)
        && (
          // p1 gets a letter, p2 unchanged
          (request.resource.data.p1Letters == resource.data.p1Letters + 1
            && request.resource.data.p2Letters == resource.data.p2Letters)
          // p2 gets a letter, p1 unchanged
          || (request.resource.data.p2Letters == resource.data.p2Letters + 1
            && request.resource.data.p1Letters == resource.data.p1Letters)
          // No letter this update (trick set phase, or successful match)
          || (request.resource.data.p1Letters == resource.data.p1Letters
            && request.resource.data.p2Letters == resource.data.p2Letters)
        )
        && (
          // Normal update (game stays active, no winner yet)
          (request.resource.data.status == 'active' && request.resource.data.winner == null)
          // Game complete: a player hit 5 letters, winner is the other player
          || (
            request.resource.data.status == 'complete'
            && (request.resource.data.p1Letters >= 5 || request.resource.data.p2Letters >= 5)
            && request.resource.data.winner == (
              request.resource.data.p1Letters >= 5
                ? resource.data.player2Uid
                : resource.data.player1Uid
            )
          )
        );

      // Either player can forfeit the current-turn player's expired turn
      // Winner must be the opponent of the player whose turn it is
      allow update: if isSignedIn()
        && isPlayer(resource.data)
        && resource.data.status == 'active'
        && request.resource.data.status == 'forfeit'
        // Cannot change player UIDs or letters
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid
        && request.resource.data.p1Letters == resource.data.p1Letters
        && request.resource.data.p2Letters == resource.data.p2Letters
        // Winner must be the opponent of the current-turn player (who timed out)
        && request.resource.data.winner == opponentUid(resource.data, resource.data.currentTurn);

      // Players may delete their own games (account deletion flow)
      allow delete: if isSignedIn() && isPlayer(resource.data);
    }
  }
}
